# specs/ontoclaw.shacl.ttl

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix oc: <http://ontoclaw.marea.software/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# ============================================================================
# ONTOLOGY HEADER
# ============================================================================

<http://ontoclaw.marea.software/shacl>
    a owl:Ontology ;
    rdfs:label "OntoClaw SHACL Shapes" ;
    rdfs:comment "Constitutional constraints for OntoClaw skill ontology" ;
    .

# ============================================================================
# BASE SKILL SHAPE
# Applies to all skills (both Executable and Declarative)
# ============================================================================

oc:SkillShape
    a sh:NodeShape ;
    sh:targetClass oc:Skill ;
    rdfs:label "Skill Shape" ;
    rdfs:comment "Base constraints that apply to all skills" ;

    # Every skill MUST have at least one resolved intent
    sh:property [
        sh:path oc:resolvesIntent ;
        sh:minCount 1 ;
        sh:message "Ogni Skill deve avere almeno un resolvesIntent (intento risolto)" ;
    ] ;

    # Every skill MUST have exactly one generatedBy attestation
    sh:property [
        sh:path oc:generatedBy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni Skill deve avere esattamente un generatedBy (modello LLM)" ;
    ] ;

    # requiresState must be an IRI (novel states are allowed - MCP server resolves them)
    sh:property [
        sh:path oc:requiresState ;
        sh:nodeKind sh:IRI ;
        sh:message "requiresState deve essere un URI" ;
    ] ;

    # yieldsState must be an IRI (novel states are allowed - MCP server resolves them)
    sh:property [
        sh:path oc:yieldsState ;
        sh:nodeKind sh:IRI ;
        sh:message "yieldsState deve essere un URI" ;
    ] ;

    # handlesFailure must be an IRI (novel states are allowed - MCP server resolves them)
    sh:property [
        sh:path oc:handlesFailure ;
        sh:nodeKind sh:IRI ;
        sh:message "handlesFailure deve essere un URI" ;
    ] ;

    # impartsKnowledge allows KnowledgeNode (typing only, no constraint)
    sh:property [
        sh:path oc:impartsKnowledge ;
        sh:class oc:KnowledgeNode ;
    ] ;
    .

# ============================================================================
# EXECUTABLE SKILL SHAPE
# Skills with execution payloads
# ============================================================================

oc:ExecutableSkillShape
    a sh:NodeShape ;
    sh:targetClass oc:ExecutableSkill ;
    rdfs:label "Executable Skill Shape" ;
    rdfs:comment "Constraints for skills with execution payloads" ;

    # MUST have exactly one payload
    sh:property [
        sh:path oc:hasPayload ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class oc:ExecutionPayload ;
        sh:message "Ogni ExecutableSkill deve avere esattamente un hasPayload" ;
    ] ;
    .

# ============================================================================
# DECLARATIVE SKILL SHAPE
# Skills without execution payloads (knowledge only)
# ============================================================================

oc:DeclarativeSkillShape
    a sh:NodeShape ;
    sh:targetClass oc:DeclarativeSkill ;
    rdfs:label "Declarative Skill Shape" ;
    rdfs:comment "Constraints for declarative/knowledge skills" ;

    # MUST NOT have a payload
    sh:property [
        sh:path oc:hasPayload ;
        sh:maxCount 0 ;
        sh:message "Le DeclarativeSkill non possono avere hasPayload" ;
    ] ;
    .

# ============================================================================
# EXECUTION PAYLOAD SHAPE
# ============================================================================

oc:ExecutionPayloadShape
    a sh:NodeShape ;
    sh:targetClass oc:ExecutionPayload ;
    rdfs:label "Execution Payload Shape" ;

    # XOR: must have either code (inline) OR executionPath (external file)
    sh:or (
        [
            sh:path oc:code ;
            sh:minCount 1 ;
        ]
        [
            sh:path oc:executionPath ;
            sh:minCount 1 ;
        ]
    ) ;
    sh:message "Un ExecutionPayload deve contenere o oc:code (inline) o oc:executionPath (file esterno)" ;

    # MUST have exactly one executor
    sh:property [
        sh:path oc:executor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("shell" "python" "node" "claude_tool") ;
        sh:message "ExecutionPayload deve avere un executor valido: shell, python, node, o claude_tool" ;
    ] ;

    # code is optional (can use executionPath instead), max 1 if present
    sh:property [
        sh:path oc:code ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Se presente, code deve essere una stringa" ;
    ] ;

    # executionPath is optional (can use code instead), max 1 if present
    sh:property [
        sh:path oc:executionPath ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Se presente, executionPath deve essere una stringa" ;
    ] ;

    # timeout is optional but must be integer if present
    sh:property [
        sh:path oc:timeout ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Se presente, timeout deve essere un intero (secondi)" ;
    ] ;
    .

# ============================================================================
# STATE SHAPE
# Validates that state instances are properly defined
# ============================================================================

oc:StateShape
    a sh:NodeShape ;
    sh:targetClass oc:State ;
    rdfs:label "State Shape" ;

    # States should have a label
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Ogni State dovrebbe avere un rdfs:label" ;
        sh:severity sh:Warning ;
    ] ;
    .

# ============================================================================
# KNOWLEDGE NODE SHAPE
# Validates epistemic knowledge nodes - STRICT
# ============================================================================

oc:KnowledgeNodeShape
    a sh:NodeShape ;
    sh:targetClass oc:KnowledgeNode ;
    rdfs:label "Knowledge Node Shape" ;
    rdfs:comment "Strict constraints for epistemic knowledge nodes" ;

    sh:property [
        sh:path oc:directiveContent ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni KnowledgeNode deve avere esattamente un directiveContent" ;
    ] ;

    sh:property [
        sh:path oc:appliesToContext ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni KnowledgeNode deve avere esattamente un appliesToContext" ;
    ] ;

    sh:property [
        sh:path oc:hasRationale ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni KnowledgeNode deve avere esattamente un hasRationale (spiegazione del perché)" ;
    ] ;

    sh:property [
        sh:path oc:severityLevel ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("CRITICAL" "HIGH" "MEDIUM" "LOW") ;
        sh:message "Se presente, severityLevel deve essere CRITICAL, HIGH, MEDIUM o LOW" ;
    ] ;
    .

# ============================================================================
# SKILL KNOWLEDGE WARNING SHAPE
# Warns if skill has no epistemic knowledge - SEPARATE FROM MAIN VALIDATION
# ============================================================================

oc:SkillKnowledgeWarningShape
    a sh:NodeShape ;
    sh:targetClass oc:Skill ;
    rdfs:label "Skill Knowledge Warning Shape" ;
    rdfs:comment "Recommends that skills impart epistemic knowledge" ;

    sh:property [
        sh:path oc:impartsKnowledge ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "ATTENZIONE: Questa Skill non fornisce nodi di conoscenza epistemica (impartsKnowledge). Considera l'aggiunta di Standard, AntiPattern o Heuristics nel file SKILL.md." ;
    ] ;
    .
