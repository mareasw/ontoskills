# specs/ontoskills.shacl.ttl

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# ============================================================================
# ONTOLOGY HEADER
# ============================================================================

<https://ontoskills.sh/shacl>
    a owl:Ontology ;
    rdfs:label "OntoSkills SHACL Shapes" ;
    rdfs:comment "Constitutional constraints for OntoSkills skill ontology" ;
    .

# ============================================================================
# BASE SKILL SHAPE
# Applies to all skills (both Executable and Declarative)
# ============================================================================

oc:SkillShape
    a sh:NodeShape ;
    sh:targetClass oc:Skill ;
    rdfs:label "Skill Shape" ;
    rdfs:comment "Base constraints that apply to all skills" ;

    # Every skill MUST have at least one resolved intent
    sh:property [
        sh:path oc:resolvesIntent ;
        sh:minCount 1 ;
        sh:message "Ogni Skill deve avere almeno un resolvesIntent (intento risolto)" ;
    ] ;

    # generatedBy is optional — migrated to system/index.json per-skill metadata
    sh:property [
        sh:path oc:generatedBy ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "generatedBy, se presente, deve essere una stringa" ;
    ] ;

    # requiresState must be an IRI (novel states are allowed - MCP server resolves them)
    sh:property [
        sh:path oc:requiresState ;
        sh:nodeKind sh:IRI ;
        sh:message "requiresState deve essere un URI" ;
    ] ;

    # yieldsState must be an IRI (novel states are allowed - MCP server resolves them)
    sh:property [
        sh:path oc:yieldsState ;
        sh:nodeKind sh:IRI ;
        sh:message "yieldsState deve essere un URI" ;
    ] ;

    # handlesFailure must be an IRI (novel states are allowed - MCP server resolves them)
    sh:property [
        sh:path oc:handlesFailure ;
        sh:nodeKind sh:IRI ;
        sh:message "handlesFailure deve essere un URI" ;
    ] ;

    # impartsKnowledge must point to a KnowledgeNode instance
    sh:property [
        sh:path oc:impartsKnowledge ;
        sh:class oc:KnowledgeNode ;
        sh:message "impartsKnowledge deve puntare a un KnowledgeNode" ;
    ] ;

    # New optional metadata properties (OntoCore refactoring)

    sh:property [
        sh:path oc:hasCategory ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "hasCategory, if present, must be a single string" ;
    ] ;

    sh:property [
        sh:path oc:hasVersion ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "hasVersion, if present, must be a single string" ;
    ] ;

    sh:property [
        sh:path oc:hasLicense ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "hasLicense, if present, must be a single string" ;
    ] ;

    sh:property [
        sh:path oc:hasAuthor ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "hasAuthor, if present, must be a single string" ;
    ] ;

    sh:property [
        sh:path oc:hasPackageName ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "hasPackageName, if present, must be a single string" ;
    ] ;

    sh:property [
        sh:path oc:isUserInvocable ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "isUserInvocable, if present, must be a boolean" ;
    ] ;

    sh:property [
        sh:path oc:hasArgumentHint ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "hasArgumentHint, if present, must be a single string" ;
    ] ;

    sh:property [
        sh:path oc:hasAllowedTool ;
        sh:datatype xsd:string ;
        sh:message "hasAllowedTool values must be strings" ;
    ] ;

    sh:property [
        sh:path oc:hasAlias ;
        sh:datatype xsd:string ;
        sh:message "hasAlias values must be strings" ;
    ] ;

    # Skill-to-skill dependency (replaces ambiguous dependsOn)
    sh:property [
        sh:path oc:dependsOnSkill ;
        sh:class oc:Skill ;
        sh:message "dependsOnSkill must point to a Skill" ;
    ] ;
    .

# ============================================================================
# EXECUTABLE SKILL SHAPE
# Skills with execution payloads
# ============================================================================

oc:ExecutableSkillShape
    a sh:NodeShape ;
    sh:targetClass oc:ExecutableSkill ;
    rdfs:label "Executable Skill Shape" ;
    rdfs:comment "Constraints for skills with execution payloads" ;

    # MUST have exactly one payload
    sh:property [
        sh:path oc:hasPayload ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class oc:ExecutionPayload ;
        sh:message "Ogni ExecutableSkill deve avere esattamente un hasPayload" ;
    ] ;
    .

# ============================================================================
# DECLARATIVE SKILL SHAPE
# Skills without execution payloads (knowledge only)
# ============================================================================

oc:DeclarativeSkillShape
    a sh:NodeShape ;
    sh:targetClass oc:DeclarativeSkill ;
    rdfs:label "Declarative Skill Shape" ;
    rdfs:comment "Constraints for declarative/knowledge skills" ;

    # MUST NOT have a payload
    sh:property [
        sh:path oc:hasPayload ;
        sh:maxCount 0 ;
        sh:message "Le DeclarativeSkill non possono avere hasPayload" ;
    ] ;
    .

# ============================================================================
# EXECUTION PAYLOAD SHAPE
# ============================================================================

oc:ExecutionPayloadShape
    a sh:NodeShape ;
    sh:targetClass oc:ExecutionPayload ;
    rdfs:label "Execution Payload Shape" ;

    # XOR: must have either code (inline) OR executionPath (external file)
    sh:or (
        [
            sh:path oc:code ;
            sh:minCount 1 ;
        ]
        [
            sh:path oc:executionPath ;
            sh:minCount 1 ;
        ]
    ) ;
    sh:message "Un ExecutionPayload deve contenere o oc:code (inline) o oc:executionPath (file esterno)" ;

    # MUST have exactly one executor
    sh:property [
        sh:path oc:executor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("shell" "python" "node" "claude_tool") ;
        sh:message "ExecutionPayload deve avere un executor valido: shell, python, node, o claude_tool" ;
    ] ;

    # code is optional (can use executionPath instead), max 1 if present
    sh:property [
        sh:path oc:code ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Se presente, code deve essere una stringa" ;
    ] ;

    # executionPath is optional (can use code instead), max 1 if present
    sh:property [
        sh:path oc:executionPath ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Se presente, executionPath deve essere una stringa" ;
    ] ;

    # timeout is optional but must be integer if present
    sh:property [
        sh:path oc:timeout ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Se presente, timeout deve essere un intero (secondi)" ;
    ] ;
    .

# ============================================================================
# STATE SHAPE
# Validates that state instances are properly defined
# ============================================================================

oc:StateShape
    a sh:NodeShape ;
    sh:targetClass oc:State ;
    rdfs:label "State Shape" ;

    # States should have a label
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Ogni State dovrebbe avere un rdfs:label" ;
        sh:severity sh:Warning ;
    ] ;
    .

# ============================================================================
# KNOWLEDGE NODE SHAPE
# Validates epistemic knowledge nodes - STRICT
# ============================================================================

oc:KnowledgeNodeShape
    a sh:NodeShape ;
    sh:targetClass oc:KnowledgeNode ;
    sh:targetObjectsOf oc:impartsKnowledge ;
    rdfs:label "Knowledge Node Shape" ;
    rdfs:comment "Strict constraints for epistemic knowledge nodes" ;

    sh:property [
        sh:path oc:directiveContent ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni KnowledgeNode deve avere esattamente un directiveContent" ;
    ] ;

    sh:property [
        sh:path oc:appliesToContext ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni KnowledgeNode deve avere esattamente un appliesToContext" ;
    ] ;

    sh:property [
        sh:path oc:hasRationale ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Ogni KnowledgeNode deve avere esattamente un hasRationale (spiegazione del perché)" ;
    ] ;

    sh:property [
        sh:path oc:severityLevel ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("CRITICAL" "HIGH" "MEDIUM" "LOW") ;
        sh:message "Se presente, severityLevel deve essere CRITICAL, HIGH, MEDIUM o LOW" ;
    ] ;
    .

# ============================================================================
# SKILL KNOWLEDGE WARNING SHAPE
# Warns if skill has no epistemic knowledge - SEPARATE FROM MAIN VALIDATION
# ============================================================================

oc:SkillKnowledgeWarningShape
    a sh:NodeShape ;
    sh:targetClass oc:Skill ;
    rdfs:label "Skill Knowledge Warning Shape" ;
    rdfs:comment "Recommends that skills impart epistemic knowledge" ;

    sh:property [
        sh:path oc:impartsKnowledge ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "ATTENZIONE: Questa Skill non fornisce nodi di conoscenza epistemica (impartsKnowledge). Considera l'aggiunta di Standard, AntiPattern o Heuristics nel file SKILL.md." ;
    ] ;
    .

# === Content Block Shapes ===

oc:CodeExampleShape a sh:NodeShape ;
    sh:targetClass oc:CodeExample ;
    sh:property [
        sh:path oc:codeLanguage ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "CodeExample must have a codeLanguage" ;
    ] , [
        sh:path oc:codeContent ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "CodeExample must have codeContent" ;
    ] .

oc:TableShape a sh:NodeShape ;
    sh:targetClass oc:Table ;
    sh:property [
        sh:path oc:tableMarkdown ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Table must have tableMarkdown" ;
    ] .

oc:FlowchartShape a sh:NodeShape ;
    sh:targetClass oc:Flowchart ;
    sh:property [
        sh:path oc:flowchartSource ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Flowchart must have flowchartSource" ;
    ] , [
        sh:path oc:flowchartType ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("graphviz" "mermaid") ;
        sh:message "Flowchart must have flowchartType (graphviz or mermaid)" ;
    ] .

oc:TemplateShape a sh:NodeShape ;
    sh:targetClass oc:Template ;
    sh:property [
        sh:path oc:templateContent ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Template must have templateContent" ;
    ] , [
        sh:path oc:templateType ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ("prompt" "output" "boilerplate") ;
        sh:message "If present, templateType must be prompt, output, or boilerplate" ;
    ] .

# === Content Model Shapes ===

oc:SectionShape a sh:NodeShape ;
    sh:targetClass oc:Section ;
    sh:property [
        sh:path oc:sectionTitle ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Section must have a sectionTitle" ;
    ] , [
        sh:path oc:sectionLevel ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Section must have a sectionLevel" ;
    ] , [
        sh:path oc:sectionOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Section must have a sectionOrder" ;
    ] .

oc:ParagraphShape a sh:NodeShape ;
    sh:targetClass oc:Paragraph ;
    sh:property [
        sh:path oc:textContent ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Paragraph must have textContent" ;
    ] , [
        sh:path oc:contentOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Paragraph must have contentOrder" ;
    ] .

oc:BulletListShape a sh:NodeShape ;
    sh:targetClass oc:BulletList ;
    sh:property [
        sh:path oc:hasItem ;
        sh:class oc:BulletItem ;
        sh:minCount 1 ;
        sh:message "BulletList must have at least one hasItem of type BulletItem" ;
    ] .

oc:BulletItemShape a sh:NodeShape ;
    sh:targetClass oc:BulletItem ;
    sh:property [
        sh:path oc:itemText ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "BulletItem must have itemText" ;
    ] , [
        sh:path oc:itemOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "BulletItem must have itemOrder" ;
    ] .

oc:BlockQuoteShape a sh:NodeShape ;
    sh:targetClass oc:BlockQuote ;
    sh:property [
        sh:path oc:quoteContent ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "BlockQuote must have quoteContent" ;
    ] , [
        sh:path oc:contentOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "BlockQuote must have contentOrder" ;
    ] , [
        sh:path oc:quoteAttribution ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "BlockQuote quoteAttribution must be a single string" ;
    ] .

# === Content Block Shapes ===

oc:HTMLBlockShape a sh:NodeShape ;
    sh:targetClass oc:HTMLBlock ;
    sh:property [
        sh:path oc:htmlContent ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "HTMLBlock must have htmlContent" ;
    ] , [
        sh:path oc:contentOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "HTMLBlock must have contentOrder" ;
    ] .

oc:FrontmatterBlockShape a sh:NodeShape ;
    sh:targetClass oc:FrontmatterBlock ;
    sh:property [
        sh:path oc:rawYaml ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "FrontmatterBlock must have rawYaml" ;
    ] , [
        sh:path oc:contentOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "FrontmatterBlock must have contentOrder" ;
    ] .
