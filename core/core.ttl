@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ontoskills.sh/ontology> a owl:Ontology ;
    dcterms:created "2026-04-19T22:25:26.897577" ;
    dcterms:description "Core TBox ontology for skill state transitions and execution" ;
    dcterms:title "OntoSkills Core Ontology" .

oc:APIKeySet a owl:Class ;
    rdfs:label "APIKeySet" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "APIKeySet" .

oc:AmbiguityTolerance a owl:Class ;
    rdfs:label "AmbiguityTolerance" ;
    rdfs:subClassOf oc:CognitiveBoundary .

oc:AntiPattern a owl:Class ;
    rdfs:label "AntiPattern" ;
    rdfs:subClassOf oc:NormativeRule .

oc:AssumptionBoundary a owl:Class ;
    rdfs:label "AssumptionBoundary" ;
    rdfs:subClassOf oc:CognitiveBoundary .

oc:ComputeCost a owl:Class ;
    rdfs:label "ComputeCost" ;
    rdfs:subClassOf oc:ResourceProfile .

oc:Constraint a owl:Class ;
    rdfs:label "Constraint" ;
    rdfs:subClassOf oc:NormativeRule .

oc:DataProvenance a owl:Class ;
    rdfs:label "DataProvenance" ;
    rdfs:subClassOf oc:TrustMetric .

oc:DeclarativeSkill a owl:Class ;
    rdfs:label "Declarative Skill" ;
    rdfs:comment "A skill without executable code (declarative knowledge)" ;
    rdfs:subClassOf oc:Skill ;
    owl:disjointWith oc:ExecutableSkill .

oc:DesignPrinciple a owl:Class ;
    rdfs:label "DesignPrinciple" ;
    rdfs:subClassOf oc:StrategicInsight .

oc:DestructivePotential a owl:Class ;
    rdfs:label "DestructivePotential" ;
    rdfs:subClassOf oc:SecurityGuardrail .

oc:DirectoryWritable a owl:Class ;
    rdfs:label "DirectoryWritable" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "DirectoryWritable" .

oc:EnvironmentReady a owl:Class ;
    rdfs:label "EnvironmentReady" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "EnvironmentReady" .

oc:ExecutionDeterminism a owl:Class ;
    rdfs:label "ExecutionDeterminism" ;
    rdfs:subClassOf oc:TrustMetric .

oc:FallbackStrategy a owl:Class ;
    rdfs:label "FallbackStrategy" ;
    rdfs:subClassOf oc:SecurityGuardrail .

oc:FileExists a owl:Class ;
    rdfs:label "FileExists" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "FileExists" .

oc:FileNotFound a owl:Class ;
    rdfs:label "FileNotFound" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "FileNotFound" .

oc:Heuristic a owl:Class ;
    rdfs:label "Heuristic" ;
    rdfs:subClassOf oc:StrategicInsight .

oc:Idempotency a owl:Class ;
    rdfs:label "Idempotency" ;
    rdfs:subClassOf oc:ExecutionPhysics .

oc:InvalidInput a owl:Class ;
    rdfs:label "InvalidInput" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "InvalidInput" .

oc:KnownIssue a owl:Class ;
    rdfs:label "KnownIssue" ;
    rdfs:subClassOf oc:ResilienceTactic .

oc:NetworkAvailable a owl:Class ;
    rdfs:label "NetworkAvailable" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "NetworkAvailable" .

oc:NetworkTimeout a owl:Class ;
    rdfs:label "NetworkTimeout" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "NetworkTimeout" .

oc:OperationFailed a owl:Class ;
    rdfs:label "OperationFailed" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "OperationFailed" .

oc:PerformanceProfile a owl:Class ;
    rdfs:label "PerformanceProfile" ;
    rdfs:subClassOf oc:ExecutionPhysics .

oc:PermissionDenied a owl:Class ;
    rdfs:label "PermissionDenied" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "PermissionDenied" .

oc:PostFlightValidation a owl:Class ;
    rdfs:label "PostFlightValidation" ;
    rdfs:subClassOf oc:LifecycleHook .

oc:PreFlightCheck a owl:Class ;
    rdfs:label "PreFlightCheck" ;
    rdfs:subClassOf oc:LifecycleHook .

oc:RecoveryTactic a owl:Class ;
    rdfs:label "RecoveryTactic" ;
    rdfs:subClassOf oc:ResilienceTactic .

oc:RequiresHumanClarification a owl:Class ;
    rdfs:label "RequiresHumanClarification" ;
    rdfs:subClassOf oc:CognitiveBoundary .

oc:RollbackProcedure a owl:Class ;
    rdfs:label "RollbackProcedure" ;
    rdfs:subClassOf oc:LifecycleHook .

oc:SecurityImplication a owl:Class ;
    rdfs:label "SecurityImplication" ;
    rdfs:subClassOf oc:SecurityGuardrail .

oc:SideEffect a owl:Class ;
    rdfs:label "SideEffect" ;
    rdfs:subClassOf oc:ExecutionPhysics .

oc:Standard a owl:Class ;
    rdfs:label "Standard" ;
    rdfs:subClassOf oc:NormativeRule .

oc:SuccessIndicator a owl:Class ;
    rdfs:label "SuccessIndicator" ;
    rdfs:subClassOf oc:Observability .

oc:SystemAuthenticated a owl:Class ;
    rdfs:label "SystemAuthenticated" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "SystemAuthenticated" .

oc:TelemetryPattern a owl:Class ;
    rdfs:label "TelemetryPattern" ;
    rdfs:subClassOf oc:Observability .

oc:TokenEconomy a owl:Class ;
    rdfs:label "TokenEconomy" ;
    rdfs:subClassOf oc:ResourceProfile .

oc:ToolInstalled a owl:Class ;
    rdfs:label "ToolInstalled" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "ToolInstalled" .

oc:WorkflowStrategy a owl:Class ;
    rdfs:label "WorkflowStrategy" ;
    rdfs:subClassOf oc:StrategicInsight .

oc:appliesToContext a owl:DatatypeProperty ;
    rdfs:label "applies to context" ;
    rdfs:comment "When this rule applies" ;
    rdfs:domain oc:KnowledgeNode .

oc:code a owl:DatatypeProperty ;
    rdfs:label "code" ;
    rdfs:comment "Executable code as a string" ;
    rdfs:domain oc:ExecutionPayload .

oc:codeContent a owl:DatatypeProperty ;
    rdfs:label "code content" ;
    rdfs:comment "Full source code of the inline example" ;
    rdfs:domain oc:CodeExample .

oc:codeContext a owl:DatatypeProperty ;
    rdfs:label "code context" ;
    rdfs:comment "LLM annotation: when to reference this code" ;
    rdfs:domain oc:CodeExample .

oc:codeLanguage a owl:DatatypeProperty ;
    rdfs:label "code language" ;
    rdfs:comment "Programming language of the code block" ;
    rdfs:domain oc:CodeExample .

oc:codePurpose a owl:DatatypeProperty ;
    rdfs:label "code purpose" ;
    rdfs:comment "LLM annotation: what this code does" ;
    rdfs:domain oc:CodeExample .

oc:contentHash a owl:DatatypeProperty ;
    rdfs:label "content hash" ;
    rdfs:comment "SHA-256 hash of skill content for deduplication" ;
    rdfs:domain oc:Skill .

oc:contradicts a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "contradicts" ;
    rdfs:comment "Skill contradicts another skill (mutually exclusive)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:dependsOn a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment "DEPRECATED: use oc:dependsOnSkill instead. Legacy skill-to-skill dependency." ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill ;
    owl:deprecated true ;
    owl:inverseOf oc:enables .

oc:dependsOnSkill a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "depends on skill" ;
    rdfs:comment "Declares a dependency on another skill (skill-to-skill prerequisite)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill ;
    owl:inverseOf oc:enablesSkill .

oc:differentia a owl:DatatypeProperty ;
    rdfs:label "differentia" ;
    rdfs:comment "Specific characteristics that differentiate this skill" ;
    rdfs:domain oc:Skill .

oc:directiveContent a owl:DatatypeProperty ;
    rdfs:label "directive content" ;
    rdfs:comment "The actual rule/guideline text" ;
    rdfs:domain oc:KnowledgeNode .

oc:exampleName a owl:DatatypeProperty ;
    rdfs:label "example name" ;
    rdfs:comment "Name of an example" ;
    rdfs:domain oc:Example .

oc:executionPath a owl:DatatypeProperty ;
    rdfs:label "execution path" ;
    rdfs:comment "Relative URI/path to the executable asset file copied by the compiler (e.g., './scripts/document.py')" ;
    rdfs:domain oc:ExecutionPayload .

oc:executor a owl:DatatypeProperty ;
    rdfs:label "executor" ;
    rdfs:comment "Executor type (e.g., 'shell', 'python', 'javascript')" ;
    rdfs:domain oc:ExecutionPayload .

oc:expectedOutcome a owl:DatatypeProperty ;
    rdfs:label "expected outcome" ;
    rdfs:comment "Expected outcome of a workflow step" ;
    rdfs:domain oc:WorkflowStep .

oc:fileHash a owl:DatatypeProperty ;
    rdfs:label "file hash" ;
    rdfs:comment "SHA-256 hash of file content" ;
    rdfs:domain oc:FileResource ;
    rdfs:range xsd:string .

oc:fileMimeType a owl:DatatypeProperty ;
    rdfs:label "file MIME type" ;
    rdfs:comment "MIME type of the file" ;
    rdfs:domain oc:FileResource ;
    rdfs:range xsd:string .

oc:filePath a owl:DatatypeProperty ;
    rdfs:label "file path" ;
    rdfs:comment "Relative path from skill directory" ;
    rdfs:domain oc:FileResource ;
    rdfs:range xsd:string .

oc:fileSize a owl:DatatypeProperty ;
    rdfs:label "file size" ;
    rdfs:comment "File size in bytes" ;
    rdfs:domain oc:FileResource ;
    rdfs:range xsd:integer .

oc:flowchartDescription a owl:DatatypeProperty ;
    rdfs:label "flowchart description" ;
    rdfs:comment "LLM annotation: what decision flow this represents" ;
    rdfs:domain oc:Flowchart .

oc:flowchartSource a owl:DatatypeProperty ;
    rdfs:label "flowchart source" ;
    rdfs:comment "Original graphviz or mermaid source" ;
    rdfs:domain oc:Flowchart .

oc:flowchartType a owl:DatatypeProperty ;
    rdfs:label "flowchart type" ;
    rdfs:comment "Diagram type: graphviz or mermaid" ;
    rdfs:domain oc:Flowchart .

oc:generatedBy a owl:DatatypeProperty ;
    rdfs:label "generated by" ;
    rdfs:comment "LLM model identifier that generated this skill (e.g., 'claude-sonnet-4-6-20250514')" ;
    rdfs:domain oc:Skill .

oc:handlesFailure a owl:ObjectProperty ;
    rdfs:label "handles failure" ;
    rdfs:comment "Failure state that this skill can handle or recover from" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:State .

oc:hasAlias a owl:DatatypeProperty ;
    rdfs:label "has alias" ;
    rdfs:comment "Alias name (repeatable — one triple per alias)" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasAllowedTool a owl:DatatypeProperty ;
    rdfs:label "has allowed tool" ;
    rdfs:comment "Allowed tool (repeatable — one triple per tool)" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasArgumentHint a owl:DatatypeProperty ;
    rdfs:label "has argument hint" ;
    rdfs:comment "Argument hint string (e.g., repo-url, query)" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasAuthor a owl:DatatypeProperty ;
    rdfs:label "has author" ;
    rdfs:comment "Author/source name (e.g., anthropics, claude-office-skills)" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasCategory a owl:DatatypeProperty ;
    rdfs:label "has category" ;
    rdfs:comment "Skill category (e.g., automation, document, marketing)" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasCodeExample a owl:ObjectProperty ;
    rdfs:label "has code example" ;
    rdfs:comment "Links a skill to an inline code example" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:CodeExample .

oc:hasConstraint a owl:DatatypeProperty ;
    rdfs:label "has constraint" ;
    rdfs:comment "Constraints or limitations on skill execution" ;
    rdfs:domain oc:Skill .

oc:hasDescription a owl:DatatypeProperty ;
    rdfs:label "has description" ;
    rdfs:comment "Description from frontmatter" ;
    rdfs:domain oc:Skill .

oc:hasExample a owl:ObjectProperty ;
    rdfs:label "has example" ;
    rdfs:comment "Links a skill to an input/output example" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Example .

oc:hasExecutableScript a owl:ObjectProperty ;
    rdfs:label "has executable script" ;
    rdfs:comment "Links a skill to an executable script" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:ExecutableScript .

oc:hasFlowchart a owl:ObjectProperty ;
    rdfs:label "has flowchart" ;
    rdfs:comment "Links a skill to a flowchart diagram" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Flowchart .

oc:hasLicense a owl:DatatypeProperty ;
    rdfs:label "has license" ;
    rdfs:comment "License identifier (e.g., MIT, Apache-2.0)" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:comment "Name from frontmatter" ;
    rdfs:domain oc:Skill .

oc:hasPackageName a owl:DatatypeProperty ;
    rdfs:label "has package name" ;
    rdfs:comment "Package ID this skill belongs to" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasPayload a owl:ObjectProperty ;
    rdfs:label "has payload" ;
    rdfs:comment "Links a skill to its execution payload" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:ExecutionPayload .

oc:hasRationale a owl:DatatypeProperty ;
    rdfs:label "has rationale" ;
    rdfs:comment "Why this rule exists" ;
    rdfs:domain oc:KnowledgeNode .

oc:hasReferenceFile a owl:ObjectProperty ;
    rdfs:label "has reference file" ;
    rdfs:comment "Links a skill to a reference file for progressive disclosure" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:ReferenceFile .

oc:hasRequirement a owl:ObjectProperty ;
    rdfs:label "has requirement" ;
    rdfs:comment "Links a skill to its requirements" ;
    rdfs:domain oc:Skill .

oc:hasStatus a owl:ObjectProperty ;
    rdfs:label "has status" ;
    rdfs:comment "Current status state of an execution attempt" ;
    rdfs:domain oc:Attempt ;
    rdfs:range oc:State .

oc:hasStep a owl:ObjectProperty ;
    rdfs:label "has step" ;
    rdfs:comment "Links a workflow to its steps" ;
    rdfs:domain oc:Workflow ;
    rdfs:range oc:WorkflowStep .

oc:hasTable a owl:ObjectProperty ;
    rdfs:label "has table" ;
    rdfs:comment "Links a skill to a markdown table" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Table .

oc:hasTag a owl:DatatypeProperty ;
    rdfs:label "has tag" ;
    rdfs:comment "Tag for categorizing examples" ;
    rdfs:domain oc:Example .

oc:hasTemplate a owl:ObjectProperty ;
    rdfs:label "has template" ;
    rdfs:comment "Links a skill to a reusable template" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Template .

oc:hasVersion a owl:DatatypeProperty ;
    rdfs:label "has version" ;
    rdfs:comment "Skill version string" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:string .

oc:hasWorkflow a owl:ObjectProperty ;
    rdfs:label "has workflow" ;
    rdfs:comment "Links a skill to a workflow" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Workflow .

oc:inputDescription a owl:DatatypeProperty ;
    rdfs:label "input description" ;
    rdfs:comment "Description of input for an example" ;
    rdfs:domain oc:Example .

oc:isOptional a owl:DatatypeProperty ;
    rdfs:label "is optional" ;
    rdfs:comment "Whether a requirement is optional or required" .

oc:isUserInvocable a owl:DatatypeProperty ;
    rdfs:label "is user invocable" ;
    rdfs:comment "Whether the skill is directly invocable by users" ;
    rdfs:domain oc:Skill ;
    rdfs:range xsd:boolean .

oc:nature a owl:DatatypeProperty ;
    rdfs:label "nature" ;
    rdfs:comment "Definition/differentia of the skill (what makes it unique)" ;
    rdfs:domain oc:Skill .

oc:outputExample a owl:DatatypeProperty ;
    rdfs:label "output example" ;
    rdfs:comment "Example output" ;
    rdfs:domain oc:Example .

oc:purpose a owl:DatatypeProperty ;
    rdfs:label "purpose" ;
    rdfs:comment "Purpose of a reference file (api-reference, examples, guide, domain-specific, other)" ;
    rdfs:domain oc:ReferenceFile .

oc:requirementType a owl:DatatypeProperty ;
    rdfs:label "requirement type" ;
    rdfs:comment "Type of requirement (Tool, EnvVar, Hardware, API, Knowledge)" ;
    rdfs:domain oc:Requirement .

oc:requirementValue a owl:DatatypeProperty ;
    rdfs:label "requirement value" ;
    rdfs:comment "Value of a requirement (e.g., tool name, version)" .

oc:requiresState a owl:ObjectProperty ;
    rdfs:label "requires state" ;
    rdfs:comment "Pre-condition state that must be satisfied before skill execution" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:State .

oc:resolvesIntent a owl:DatatypeProperty ;
    rdfs:label "resolves intent" ;
    rdfs:comment "User intent that this skill can resolve" ;
    rdfs:domain oc:Skill .

oc:rowCount a owl:DatatypeProperty ;
    rdfs:label "row count" ;
    rdfs:comment "Number of data rows in the table" ;
    rdfs:domain oc:Table ;
    rdfs:range xsd:integer .

oc:scriptCommand a owl:DatatypeProperty ;
    rdfs:label "script command" ;
    rdfs:comment "Command template for executing the script" ;
    rdfs:domain oc:ExecutableScript ;
    rdfs:range xsd:string .

oc:scriptExecutor a owl:DatatypeProperty ;
    rdfs:label "script executor" ;
    rdfs:comment "Executor for the script (python, bash, node, etc.)" ;
    rdfs:domain oc:ExecutableScript ;
    rdfs:range xsd:string .

oc:scriptHasRequirement a owl:ObjectProperty ;
    rdfs:label "script has requirement" ;
    rdfs:comment "Links an executable script to its requirements" ;
    rdfs:domain oc:ExecutableScript ;
    rdfs:range oc:Requirement .

oc:scriptIntent a owl:DatatypeProperty ;
    rdfs:label "script intent" ;
    rdfs:comment "Whether script should be executed or is read-only" ;
    rdfs:domain oc:ExecutableScript ;
    rdfs:range xsd:string .

oc:scriptOutput a owl:DatatypeProperty ;
    rdfs:label "script output" ;
    rdfs:comment "Description of what the script produces" ;
    rdfs:domain oc:ExecutableScript ;
    rdfs:range xsd:string .

oc:severityLevel a owl:DatatypeProperty ;
    rdfs:label "severity level" ;
    rdfs:comment "Must be one of: CRITICAL, HIGH, MEDIUM, LOW" ;
    rdfs:domain oc:KnowledgeNode .

oc:sourceLocation a owl:DatatypeProperty ;
    rdfs:label "source location" ;
    rdfs:comment "Line range in original markdown" ;
    rdfs:domain oc:CodeExample .

oc:stepDependsOn a owl:ObjectProperty ;
    rdfs:label "step depends on" ;
    rdfs:comment "Indicates that one workflow step depends on another step" ;
    rdfs:domain oc:WorkflowStep ;
    rdfs:range oc:WorkflowStep .

oc:stepId a owl:DatatypeProperty ;
    rdfs:label "step ID" ;
    rdfs:comment "Unique identifier for a workflow step" ;
    rdfs:domain oc:WorkflowStep .

oc:stepOrder a owl:DatatypeProperty ;
    rdfs:label "step order" ;
    rdfs:comment "Position of this step in a linear procedure (1-based)" ;
    rdfs:domain oc:WorkflowStep ;
    rdfs:range xsd:integer .

oc:tableCaption a owl:DatatypeProperty ;
    rdfs:label "table caption" ;
    rdfs:comment "Caption or title of the table" ;
    rdfs:domain oc:Table .

oc:tableMarkdown a owl:DatatypeProperty ;
    rdfs:label "table markdown" ;
    rdfs:comment "Original markdown source of the table" ;
    rdfs:domain oc:Table .

oc:tablePurpose a owl:DatatypeProperty ;
    rdfs:label "table purpose" ;
    rdfs:comment "LLM annotation: what this table represents" ;
    rdfs:domain oc:Table .

oc:templateContent a owl:DatatypeProperty ;
    rdfs:label "template content" ;
    rdfs:comment "Full template source text" ;
    rdfs:domain oc:Template .

oc:templateType a owl:DatatypeProperty ;
    rdfs:label "template type" ;
    rdfs:comment "Kind of template: prompt, output, or boilerplate" ;
    rdfs:domain oc:Template .

oc:templateVariables a owl:DatatypeProperty ;
    rdfs:label "template variables" ;
    rdfs:comment "Variable placeholder name (repeatable)" ;
    rdfs:domain oc:Template .

oc:timeout a owl:DatatypeProperty ;
    rdfs:label "timeout" ;
    rdfs:comment "Execution timeout in seconds" ;
    rdfs:domain oc:ExecutionPayload .

oc:workflowId a owl:DatatypeProperty ;
    rdfs:label "workflow ID" ;
    rdfs:comment "Unique identifier for a workflow" ;
    rdfs:domain oc:Workflow .

oc:workflowName a owl:DatatypeProperty ;
    rdfs:label "workflow name" ;
    rdfs:comment "Human-readable name for a workflow" ;
    rdfs:domain oc:Workflow .

oc:yieldsState a owl:ObjectProperty ;
    rdfs:label "yields state" ;
    rdfs:comment "State that results from successful skill execution" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:State .

oc:Attempt a owl:Class ;
    rdfs:label "Attempt" ;
    rdfs:comment "Record of a skill execution attempt, used for negative memory" .

oc:ExecutableSkill a owl:Class ;
    rdfs:label "Executable Skill" ;
    rdfs:comment "A skill with an executable code payload" ;
    rdfs:subClassOf oc:Skill .

oc:FileResourceUnion rdf:first oc:ReferenceFile ;
    rdf:rest ( oc:ExecutableScript ) .

oc:enables a owl:ObjectProperty ;
    rdfs:label "enables" ;
    rdfs:comment "Skill enables another skill (inverse of dependsOn)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:enablesSkill a owl:ObjectProperty ;
    rdfs:label "enables skill" ;
    rdfs:comment "Skill enables another skill (inverse of dependsOnSkill)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:extends a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "extends" ;
    rdfs:comment "Skill extends another skill (inheritance)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill ;
    owl:inverseOf oc:isExtendedBy .

oc:impartsKnowledge a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "imparts knowledge" ;
    rdfs:comment "Links a skill to epistemic knowledge it imparts to the agent" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:KnowledgeNode ;
    rdfs:subPropertyOf oc:inheritsKnowledge .

oc:inheritsKnowledge a owl:ObjectProperty ;
    rdfs:label "inherits knowledge" ;
    owl:propertyChainAxiom ( oc:extends oc:impartsKnowledge ) .

oc:isExtendedBy a owl:ObjectProperty ;
    rdfs:label "is extended by" ;
    rdfs:comment "Inverse of extends" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:Observability a owl:Class ;
    rdfs:label "Observability" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:Requirement a owl:Class ;
    rdfs:label "Requirement" ;
    rdfs:comment "A generic requirement (tool, environment variable, etc.)" .

oc:ResilienceTactic a owl:Class ;
    rdfs:label "ResilienceTactic" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ResourceProfile a owl:Class ;
    rdfs:label "ResourceProfile" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:TrustMetric a owl:Class ;
    rdfs:label "TrustMetric" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:CognitiveBoundary a owl:Class ;
    rdfs:label "CognitiveBoundary" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ExecutionPhysics a owl:Class ;
    rdfs:label "ExecutionPhysics" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:LifecycleHook a owl:Class ;
    rdfs:label "LifecycleHook" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:NormativeRule a owl:Class ;
    rdfs:label "NormativeRule" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ReferenceFile a owl:Class ;
    rdfs:label "Reference File" ;
    rdfs:comment "A reference file for progressive disclosure (e.g., API docs, examples)" .

oc:SecurityGuardrail a owl:Class ;
    rdfs:label "SecurityGuardrail" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:StrategicInsight a owl:Class ;
    rdfs:label "StrategicInsight" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:FileResource a owl:Class ;
    owl:unionOf oc:FileResourceUnion .

oc:Flowchart a owl:Class ;
    rdfs:label "Flowchart" ;
    rdfs:comment "Graphviz or Mermaid diagram extracted from skill content" .

oc:Template a owl:Class ;
    rdfs:label "Template" ;
    rdfs:comment "Reusable template with variable placeholders" .

oc:Workflow a owl:Class ;
    rdfs:label "Workflow" ;
    rdfs:comment "A sequential workflow with dependencies between steps" .

oc:Example a owl:Class ;
    rdfs:label "Example" ;
    rdfs:comment "An input/output example for pattern matching" .

oc:ExecutionPayload a owl:Class ;
    rdfs:label "Execution Payload" ;
    rdfs:comment "Container for executable code and execution metadata" .

oc:Table a owl:Class ;
    rdfs:label "Table" ;
    rdfs:comment "Markdown table extracted from skill content" .

oc:CodeExample a owl:Class ;
    rdfs:label "Code Example" ;
    rdfs:comment "Inline code block extracted from skill markdown" .

oc:WorkflowStep a owl:Class ;
    rdfs:label "Workflow Step" ;
    rdfs:comment "A single step in a workflow with optional dependencies" .

oc:ExecutableScript a owl:Class ;
    rdfs:label "Executable Script" ;
    rdfs:comment "An executable script associated with a skill" .

oc:KnowledgeNode a owl:Class ;
    rdfs:label "Knowledge Node" ;
    rdfs:comment "Epistemic knowledge imparted by a skill to an agent" .

oc:State a owl:Class ;
    rdfs:label "State" ;
    rdfs:comment "Abstract class representing a system state (precondition, outcome, or failure)" .

oc:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "Base class for all executable skills in the ontology" .

