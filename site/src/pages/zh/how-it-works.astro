---
import LandingLayout from '../../layouts/LandingLayout.astro';
import Header from '../../components/landing/Header.astro';
import Footer from '../../components/landing/Footer.astro';
import Button from '../../components/ui/Button.astro';

const steps = [
  {
    number: 1,
    title: 'SKILL.md',
    subtitle: '人工编写',
    description: '技能使用带有 YAML 前置元数据的 Markdown 编写。开发者编写清晰的说明，定义意图，并构建 AI 代理可以理解和执行的内容结构。',
    bullets: [
      'YAML 前置元数据',
      'Markdown 正文说明',
      '与代码一起版本控制',
      '人类可读，AI 友好'
    ],
    code: `---
name: tdd-workflow
description: 测试驱动开发
intents:
  - write_tests_first
---

## 说明
1. 先写测试
2. 运行测试（失败）
3. 编写最小代码
4. 运行测试（通过）
5. 重构`
  },
  {
    number: 2,
    title: 'OntoCore',
    subtitle: '编译器',
    description: 'OntoCore 将 SKILL.md 文件编译为 OWL 2 DL 本体。编译器验证结构，提取语义关系，并生成机器可读的 RDF 三元组。',
    bullets: [
      '解析和验证 SKILL.md',
      '提取语义关系',
      '生成 OWL 2 DL 本体',
      'SHACL 验证内置'
    ],
    code: `$ npx ontoskills compile

  解析 tdd-workflow/SKILL.md...
  验证结构...
  生成本体...
  写入三元组...

  ✓ 编译到 ontoskills/tdd-workflow.ttl`
  },
  {
    number: 3,
    title: '.ttl 文件',
    subtitle: '本体',
    description: '编译后的 Turtle (.ttl) 文件包含本体 — 使用 RDF 三元组和 OWL 语义对技能、意图及其关系的形式化表示。',
    bullets: [
      '标准 RDF Turtle 格式',
      'OWL 2 DL 定义',
      'SPARQL 可查询图',
      '语义技能关系'
    ],
    code: `@prefix oc: <https://ontoskills.dev/ns#> .

oc:tdd-workflow a oc:Skill ;
  oc:name "tdd-workflow" ;
  oc:description "测试驱动开发" ;
  oc:resolvesIntent "write_tests_first" ;
  oc:hasStep oc:write-test,
             oc:run-test,
             oc:implement .`
  },
  {
    number: 4,
    title: 'OntoMCP',
    subtitle: '运行时',
    description: 'OntoMCP 是基于 Rust 的 MCP 运行时，它加载本体并通过模型上下文协议以亚毫秒级响应时间为 AI 代理提供技能查询服务。',
    bullets: [
      '原生 Rust 性能',
      'MCP 协议实现',
      '亚毫秒级 SPARQL',
      '基于意图的发现'
    ],
    code: `# 按意图搜索技能
search_intents("create_pdf")
  → pdf-generator
  → report-exporter

# 获取技能上下文
get_skill("pdf-generator")
  → { name, description, instructions }`
  }
];
---

<LandingLayout title="工作原理 - OntoSkills" lang="zh">
  <Header lang="zh" />
  <main>
    <!-- Hero Section -->
    <section class="pt-20 pb-8">
      <div class="section-shell">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#52c7e8]/10 border border-[#52c7e8]/20 text-[#52c7e8] text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            管道
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary mb-6 tracking-tight">
            <span class="gradient-text">工作原理</span>
          </h1>
          <p class="text-xl text-text-secondary max-w-2xl mx-auto">
            从 SKILL.md 到确定性执行的 4 个简单步骤
          </p>
        </div>
      </div>
    </section>

    <!-- Pipeline Overview -->
    <section class="pb-12 overflow-x-auto">
      <div class="section-shell">
        <div class="flex flex-col lg:flex-row items-center justify-center gap-2 lg:gap-0 min-w-max lg:min-w-0">
          {steps.map((step, index) => (
            <>
              <div class="pipeline-step flex flex-col items-center text-center px-4 lg:px-6 py-4">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#52c7e8]/20 to-[#85f496]/20 border border-[#52c7e8]/30 flex items-center justify-center text-[#52c7e8] mb-3 relative">
                  <span class="text-xl font-bold">{step.number}</span>
                  <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-[#52c7e8] text-[10px] font-bold text-black flex items-center justify-center">
                    {index + 1}
                  </div>
                </div>
                <div class="font-semibold text-text-primary text-sm whitespace-nowrap">{step.title}</div>
                <div class="text-xs text-text-muted whitespace-nowrap">{step.subtitle}</div>
              </div>
              {index < steps.length - 1 && (
                <div class="pipeline-arrow hidden lg:flex items-center text-[#52c7e8]/40">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              )}
              {index < steps.length - 1 && (
                <div class="lg:hidden flex items-center text-[#52c7e8]/40 my-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                  </svg>
                </div>
              )}
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- Detailed Steps with Alternating Layout -->
    <section class="pb-20">
      <div class="section-shell">
        <div class="space-y-24 lg:space-y-32">
          {steps.map((step, index) => (
            <div class="step-section" id={`step-${step.number}`}>
              <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                <!-- Content Column -->
                <div class={`space-y-5 ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
                  <div class="flex items-center gap-4">
                    <div class="flex items-center gap-3">
                      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#52c7e8]/20 to-[#85f496]/20 border border-[#52c7e8]/30 flex items-center justify-center">
                        <span class="text-xl font-bold text-[#52c7e8]">{step.number}</span>
                      </div>
                      <div>
                        <h2 class="text-2xl sm:text-3xl font-bold text-text-primary">{step.title}</h2>
                        <p class="text-sm text-[#52c7e8] font-medium">{step.subtitle}</p>
                      </div>
                    </div>
                  </div>

                  <p class="text-text-secondary leading-relaxed text-lg">
                    {step.description}
                  </p>

                  <ul class="space-y-3">
                    {step.bullets.map((bullet) => (
                      <li class="flex items-center gap-3">
                        <div class="w-5 h-5 rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center flex-shrink-0">
                          <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <span class="text-text-secondary">{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Code Column -->
                <div class={` ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
                  <div class="relative">
                    <div class="absolute -inset-1 bg-gradient-to-r from-[#52c7e8]/20 to-[#85f496]/20 rounded-2xl blur-xl opacity-50"></div>
                    <div class="relative bg-bg-elevated border border-white/10 rounded-2xl overflow-hidden">
                      <div class="flex items-center justify-between px-4 py-3 border-b border-white/5 bg-black/20">
                        <div class="flex items-center gap-2">
                          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                          <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                          <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
                        </div>
                        <span class="text-xs text-text-muted font-mono">{step.number === 1 ? 'SKILL.md' : step.number === 2 ? 'terminal' : step.number === 3 ? 'output.ttl' : 'mcp-query'}</span>
                      </div>
                      <div class="p-4 sm:p-6 overflow-x-auto">
                        <pre class="text-sm font-mono text-text-secondary whitespace-pre-wrap"><code>{step.code}</code></pre>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="section-shell">
        <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-[#52c7e8]/5 via-bg-elevated to-[#85f496]/5 p-8 sm:p-12 lg:p-16">
          <div class="absolute top-0 right-0 w-96 h-96 bg-[#52c7e8]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#85f496]/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

          <div class="relative text-center">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-4 tracking-tight">
              准备好编译你的第一个技能了吗？
            </h2>
            <p class="text-text-secondary mb-8 max-w-xl mx-auto text-lg">
              几分钟内开始使用 OntoSkills。编写你的第一个 SKILL.md，将其编译为本体，并通过 MCP 查询。
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <Button href="/zh/getting-started/" size="lg">开始使用</Button>
              <Button href="/zh/ontostore/" variant="secondary" size="lg">浏览 OntoStore</Button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="zh" />
</LandingLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html) {
      scroll-behavior: auto;
    }
  }

  .pipeline-step {
    transition: transform 0.2s ease;
  }

  .pipeline-step:hover {
    transform: translateY(-2px);
  }

  .step-section {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.6s ease forwards;
  }

  .step-section:nth-child(1) { animation-delay: 0.1s; }
  .step-section:nth-child(2) { animation-delay: 0.2s; }
  .step-section:nth-child(3) { animation-delay: 0.3s; }
  .step-section:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .step-section {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .pipeline-step:hover {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    pre {
      font-size: 0.75rem;
    }
  }
</style>
