---
import Button from '../ui/Button.astro';
---

<section class="py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
      Install. Enable. <span class="gradient-text">Query.</span>
    </h2>
    <p class="text-text-muted mb-8 max-w-2xl mx-auto">
      Start with the managed CLI, pull from the official registry, and let OntoMCP serve the enabled skill set.
      Use OntoCore only when you need to author your own source skills.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/overview/" size="lg">
        Get Started
      </Button>
      <Button href="https://github.com/mareasoftware/OntoSkillRegistry" variant="secondary" size="lg">
        Browse Registry
      </Button>
    </div>
  </div>
</section>
