---
import logo from '../../assets/ontoskills-logo.png';
import { type Lang, translations, defaultLang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = translations.footer[lang];

// All pages use /{lang}/... convention
const href = (subpath: string) => `/${lang}/${subpath}/`;
const homeHref = `/${lang}/`;

const productLinks = [
  { label: 'OntoCore', href: href('ontocore') },
  { label: 'OntoStore', href: href('ontostore') },
  { label: 'OntoMCP', href: href('mcp') },
  { label: t.roadmap, href: href('roadmap') }
];

const resourceLinks = [
  { label: t.documentation, href: href('overview') },
  { label: t.gettingStarted, href: href('getting-started') },
  { label: t.cliReference, href: href('cli') },
  { label: t.architecture, href: href('architecture') }
];

const communityLinks = [
  { label: 'GitHub', href: 'https://github.com/mareasw/ontoskills', external: true },
  { label: 'OntoStore Repo', href: 'https://github.com/mareasw/ontostore', external: true },
  { label: 'Philosophy', href: 'https://github.com/mareasw/ontoskills/blob/main/PHILOSOPHY.md', external: true }
];
---

<footer class="border-t border-white/10 py-12 sm:py-16 bg-transparent relative overflow-hidden">
  <!-- Subtle gradient background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-t from-[#52c7e8]/5 to-transparent rounded-full blur-3xl"></div>
  </div>

  <div class="section-shell relative">
    <!-- Logo at top -->
    <div class="flex justify-center mb-10 sm:mb-12">
      <a href={homeHref} class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <img src={logo.src} alt="OntoSkills" class="h-6 w-auto" />
        <span class="font-semibold text-text-primary">OntoSkills</span>
      </a>
    </div>

    <!-- 3-column grid - centered with max-width -->
    <div class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-6 mb-10 sm:mb-12 text-center">
        <!-- Product Column -->
        <div>
          <h3 class="font-semibold text-text-primary mb-4 text-sm uppercase tracking-wider">{t.product}</h3>
          <nav class="flex flex-col items-center gap-3">
            {productLinks.map((link) => (
              <a
                href={link.href}
                class="text-text-secondary hover:text-[#85f496] transition-colors text-sm"
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>

        <!-- Resources Column -->
        <div>
          <h3 class="font-semibold text-text-primary mb-4 text-sm uppercase tracking-wider">{t.resources}</h3>
          <nav class="flex flex-col items-center gap-3">
            {resourceLinks.map((link) => (
              <a
                href={link.href}
                class="text-text-secondary hover:text-[#85f496] transition-colors text-sm"
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>

        <!-- Community Column -->
        <div>
          <h3 class="font-semibold text-text-primary mb-4 text-sm uppercase tracking-wider">{t.community}</h3>
          <nav class="flex flex-col items-center gap-3">
            {communityLinks.map((link) => (
              <a
                href={link.href}
                class="text-text-secondary hover:text-[#85f496] transition-colors text-sm inline-flex items-center gap-1.5"
                target="_blank"
                rel="noopener"
              >
                {link.label}
                <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ))}
          </nav>
        </div>
      </div>
    </div>

    <!-- Copyright line at bottom -->
    <div class="text-center text-text-muted text-sm pt-8 border-t border-white/5">
      {t.copyright}
    </div>
  </div>
</footer>
