---
const phases = [
  {
    status: 'done',
    phase: 'Phase 1',
    title: 'OntoCore',
    description: 'Neuro-symbolic core: SKILL.md → OWL 2 DL ontology',
  },
  {
    status: 'done',
    phase: 'Phase 2',
    title: 'OntoSkills',
    description: 'Compiled skill library ready for agent queries',
  },
  {
    status: 'done',
    phase: 'Phase 3',
    title: 'OntoMCP',
    description: 'Rust MCP server with 12 semantic tools',
  },
  {
    status: 'wip',
    phase: 'Phase 4',
    title: 'OntoStore',
    description: 'Centralized marketplace for ontologies',
  },
  {
    status: 'planned',
    phase: 'Phase 5',
    title: 'OntoAgent',
    description: 'Autonomous agent powered by structured knowledge',
  },
];

const statusStyles = {
  done: 'border-accent-mint text-accent-mint',
  wip: 'border-accent-cyan text-accent-cyan animate-pulse',
  planned: 'border-text-muted text-text-muted',
  future: 'border-border text-text-muted opacity-60',
};

const statusIcons = {
  done: '✓',
  wip: '🔨',
  planned: '💡',
  future: '🔮',
};
---

<section id="roadmap" class="py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        <span class="gradient-text">Roadmap</span>
      </h2>
      <p class="text-text-muted">
        This evolves as we build.
      </p>
    </div>

    <div class="relative px-4">
      <!-- Timeline line -->
      <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-border md:-translate-x-px"></div>

      <!-- Phases -->
      <div class="space-y-8">
        {phases.map((phase, i) => (
          <div class={`relative flex items-start gap-6 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <!-- Marker -->
            <div class={`absolute left-8 md:left-1/2 w-8 h-8 rounded-full border-2 bg-bg-primary flex items-center justify-center text-sm -translate-x-1/2 ${statusStyles[phase.status]}`}>
              {statusIcons[phase.status]}
            </div>

            <!-- Content -->
            <div class={`ml-20 md:ml-0 md:w-1/2 px-2 ${i % 2 === 1 ? 'md:pr-20 md:text-right' : 'md:pl-20'}`}>
              <span class="text-xs uppercase tracking-wider text-text-muted">{phase.phase}</span>
              <h3 class="text-xl font-bold text-text-primary mt-1">{phase.title}</h3>
              <p class="text-text-muted mt-2">{phase.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 text-center">
      <p class="text-text-muted text-sm">
        Track progress on <a href="https://github.com/mareasoftware/ontoskills" class="text-accent-cyan hover:underline">GitHub</a>
      </p>
    </div>
  </div>
</section>
