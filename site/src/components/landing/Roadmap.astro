---
import { type Lang, translations, defaultLang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = translations.roadmap[lang];
---

<section class="roadmap-section py-20 border-b border-white/10 relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-gradient-to-r from-[#52c7e8]/5 via-[#85f496]/5 to-[#92eff4]/5 rounded-full blur-3xl"></div>
  </div>

  <div class="section-shell relative">
    <div class="max-w-2xl mx-auto">
      <div class="border border-white/10 bg-bg-elevated rounded-xl p-8 hover:border-[#52c7e8]/30 transition-all duration-300 relative overflow-hidden group">
        <!-- Gradient border top -->
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#52c7e8]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-[#52c7e8]/10 to-[#85f496]/10 border border-[#52c7e8]/30 flex items-center justify-center">
            <svg class="w-6 h-6 text-[#52c7e8]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold">{t.title}</h3>
            <p class="text-sm text-[#52c7e8]">{t.subtitle}</p>
          </div>
        </div>

        <p class="text-text-secondary mb-4">
          {t.description}
        </p>

        <div class="inline-block px-3 py-1 bg-orange-500/10 border border-orange-500/30 rounded-full text-sm text-orange-400">
          {t.badge}
        </div>
      </div>
    </div>
  </div>
</section>
