---
import Button from '../ui/Button.astro';
import GraphBackground from './GraphBackground.astro';
---

<section class="relative overflow-hidden">
  <!-- Animated Graph Background -->
  <GraphBackground />

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
      <span class="text-text-primary">Skills become</span>
      <br />
      <span class="gradient-text">registry-backed knowledge</span>
    </h1>

    <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto mb-8">
      <span class="text-accent-cyan font-medium">OntoSkills</span> connects the official registry, the <code class="text-accent-aqua">ontoskills</code> CLI,
      the <code class="text-accent-aqua">ontomcp</code> runtime, and the optional <code class="text-accent-aqua">ontocore</code> compiler.
      Install, enable, and query deterministic skills instead of scraping files by hand.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/overview/" size="lg">
        Get Started
      </Button>
      <Button href="https://github.com/mareasoftware/OntoSkillRegistry" variant="secondary" size="lg">
        Browse Registry
      </Button>
    </div>
  </div>
</section>
