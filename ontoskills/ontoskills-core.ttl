@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://ontoskills.sh/ontology> a owl:Ontology ;
    dcterms:created "2026-03-20T17:27:12.958911" ;
    dcterms:description "Core TBox ontology for skill state transitions and execution" ;
    dcterms:title "OntoSkills Core Ontology" .

oc:APIKeySet a owl:Class ;
    rdfs:label "APIKeySet" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "APIKeySet" .

oc:AmbiguityTolerance a owl:Class ;
    rdfs:label "AmbiguityTolerance" ;
    rdfs:subClassOf oc:CognitiveBoundary .

oc:AntiPattern a owl:Class ;
    rdfs:label "AntiPattern" ;
    rdfs:subClassOf oc:NormativeRule .

oc:AssumptionBoundary a owl:Class ;
    rdfs:label "AssumptionBoundary" ;
    rdfs:subClassOf oc:CognitiveBoundary .

oc:ComputeCost a owl:Class ;
    rdfs:label "ComputeCost" ;
    rdfs:subClassOf oc:ResourceProfile .

oc:Constraint a owl:Class ;
    rdfs:label "Constraint" ;
    rdfs:subClassOf oc:NormativeRule .

oc:DataProvenance a owl:Class ;
    rdfs:label "DataProvenance" ;
    rdfs:subClassOf oc:TrustMetric .

oc:DeclarativeSkill a owl:Class ;
    rdfs:label "Declarative Skill" ;
    rdfs:comment "A skill without executable code (declarative knowledge)" ;
    rdfs:subClassOf oc:Skill ;
    owl:disjointWith oc:ExecutableSkill .

oc:DesignPrinciple a owl:Class ;
    rdfs:label "DesignPrinciple" ;
    rdfs:subClassOf oc:StrategicInsight .

oc:DestructivePotential a owl:Class ;
    rdfs:label "DestructivePotential" ;
    rdfs:subClassOf oc:SecurityGuardrail .

oc:DirectoryWritable a owl:Class ;
    rdfs:label "DirectoryWritable" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "DirectoryWritable" .

oc:EnvironmentReady a owl:Class ;
    rdfs:label "EnvironmentReady" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "EnvironmentReady" .

oc:ExecutionDeterminism a owl:Class ;
    rdfs:label "ExecutionDeterminism" ;
    rdfs:subClassOf oc:TrustMetric .

oc:FallbackStrategy a owl:Class ;
    rdfs:label "FallbackStrategy" ;
    rdfs:subClassOf oc:SecurityGuardrail .

oc:FileExists a owl:Class ;
    rdfs:label "FileExists" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "FileExists" .

oc:FileNotFound a owl:Class ;
    rdfs:label "FileNotFound" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "FileNotFound" .

oc:Heuristic a owl:Class ;
    rdfs:label "Heuristic" ;
    rdfs:subClassOf oc:StrategicInsight .

oc:Idempotency a owl:Class ;
    rdfs:label "Idempotency" ;
    rdfs:subClassOf oc:ExecutionPhysics .

oc:InvalidInput a owl:Class ;
    rdfs:label "InvalidInput" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "InvalidInput" .

oc:KnownIssue a owl:Class ;
    rdfs:label "KnownIssue" ;
    rdfs:subClassOf oc:ResilienceTactic .

oc:NetworkAvailable a owl:Class ;
    rdfs:label "NetworkAvailable" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "NetworkAvailable" .

oc:NetworkTimeout a owl:Class ;
    rdfs:label "NetworkTimeout" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "NetworkTimeout" .

oc:OperationFailed a owl:Class ;
    rdfs:label "OperationFailed" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "OperationFailed" .

oc:PerformanceProfile a owl:Class ;
    rdfs:label "PerformanceProfile" ;
    rdfs:subClassOf oc:ExecutionPhysics .

oc:PermissionDenied a owl:Class ;
    rdfs:label "PermissionDenied" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "PermissionDenied" .

oc:PostFlightValidation a owl:Class ;
    rdfs:label "PostFlightValidation" ;
    rdfs:subClassOf oc:LifecycleHook .

oc:PreFlightCheck a owl:Class ;
    rdfs:label "PreFlightCheck" ;
    rdfs:subClassOf oc:LifecycleHook .

oc:RecoveryTactic a owl:Class ;
    rdfs:label "RecoveryTactic" ;
    rdfs:subClassOf oc:ResilienceTactic .

oc:RequiresHumanClarification a owl:Class ;
    rdfs:label "RequiresHumanClarification" ;
    rdfs:subClassOf oc:CognitiveBoundary .

oc:RollbackProcedure a owl:Class ;
    rdfs:label "RollbackProcedure" ;
    rdfs:subClassOf oc:LifecycleHook .

oc:SecurityImplication a owl:Class ;
    rdfs:label "SecurityImplication" ;
    rdfs:subClassOf oc:SecurityGuardrail .

oc:SideEffect a owl:Class ;
    rdfs:label "SideEffect" ;
    rdfs:subClassOf oc:ExecutionPhysics .

oc:Standard a owl:Class ;
    rdfs:label "Standard" ;
    rdfs:subClassOf oc:NormativeRule .

oc:SuccessIndicator a owl:Class ;
    rdfs:label "SuccessIndicator" ;
    rdfs:subClassOf oc:Observability .

oc:SystemAuthenticated a owl:Class ;
    rdfs:label "SystemAuthenticated" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "SystemAuthenticated" .

oc:TelemetryPattern a owl:Class ;
    rdfs:label "TelemetryPattern" ;
    rdfs:subClassOf oc:Observability .

oc:TokenEconomy a owl:Class ;
    rdfs:label "TokenEconomy" ;
    rdfs:subClassOf oc:ResourceProfile .

oc:ToolInstalled a owl:Class ;
    rdfs:label "ToolInstalled" ;
    rdfs:subClassOf oc:State ;
    skos:prefLabel "ToolInstalled" .

oc:WorkflowStrategy a owl:Class ;
    rdfs:label "WorkflowStrategy" ;
    rdfs:subClassOf oc:StrategicInsight .

oc:appliesToContext a owl:DatatypeProperty ;
    rdfs:label "applies to context" ;
    rdfs:comment "When this rule applies" ;
    rdfs:domain oc:KnowledgeNode .

oc:code a owl:DatatypeProperty ;
    rdfs:label "code" ;
    rdfs:comment "Executable code as a string" ;
    rdfs:domain oc:ExecutionPayload .

oc:contentHash a owl:DatatypeProperty ;
    rdfs:label "content hash" ;
    rdfs:comment "SHA-256 hash of skill content for deduplication" ;
    rdfs:domain oc:Skill .

oc:contradicts a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "contradicts" ;
    rdfs:comment "Skill contradicts another skill (mutually exclusive)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:dependsOn a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment "Skill depends on another skill (prerequisite)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill ;
    owl:inverseOf oc:enables .

oc:differentia a owl:DatatypeProperty ;
    rdfs:label "differentia" ;
    rdfs:comment "Specific characteristics that differentiate this skill" ;
    rdfs:domain oc:Skill .

oc:directiveContent a owl:DatatypeProperty ;
    rdfs:label "directive content" ;
    rdfs:comment "The actual rule/guideline text" ;
    rdfs:domain oc:KnowledgeNode .

oc:executionPath a owl:DatatypeProperty ;
    rdfs:label "execution path" ;
    rdfs:comment "Relative URI/path to the executable asset file copied by the compiler (e.g., './scripts/document.py')" ;
    rdfs:domain oc:ExecutionPayload .

oc:executor a owl:DatatypeProperty ;
    rdfs:label "executor" ;
    rdfs:comment "Executor type (e.g., 'shell', 'python', 'javascript')" ;
    rdfs:domain oc:ExecutionPayload .

oc:generatedBy a owl:DatatypeProperty ;
    rdfs:label "generated by" ;
    rdfs:comment "LLM model identifier that generated this skill (e.g., 'claude-sonnet-4-6-20250514')" ;
    rdfs:domain oc:Skill .

oc:handlesFailure a owl:ObjectProperty ;
    rdfs:label "handles failure" ;
    rdfs:comment "Failure state that this skill can handle or recover from" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:State .

oc:hasConstraint a owl:DatatypeProperty ;
    rdfs:label "has constraint" ;
    rdfs:comment "Constraints or limitations on skill execution" ;
    rdfs:domain oc:Skill .

oc:hasPayload a owl:ObjectProperty ;
    rdfs:label "has payload" ;
    rdfs:comment "Links a skill to its execution payload" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:ExecutionPayload .

oc:hasRationale a owl:DatatypeProperty ;
    rdfs:label "has rationale" ;
    rdfs:comment "Why this rule exists" ;
    rdfs:domain oc:KnowledgeNode .

oc:hasRequirement a owl:ObjectProperty ;
    rdfs:label "has requirement" ;
    rdfs:comment "Links a skill to its requirements" ;
    rdfs:domain oc:Skill .

oc:hasStatus a owl:ObjectProperty ;
    rdfs:label "has status" ;
    rdfs:comment "Current status state of an execution attempt" ;
    rdfs:domain oc:Attempt ;
    rdfs:range oc:State .

oc:isOptional a owl:DatatypeProperty ;
    rdfs:label "is optional" ;
    rdfs:comment "Whether a requirement is optional or required" .

oc:nature a owl:DatatypeProperty ;
    rdfs:label "nature" ;
    rdfs:comment "Definition/differentia of the skill (what makes it unique)" ;
    rdfs:domain oc:Skill .

oc:requirementValue a owl:DatatypeProperty ;
    rdfs:label "requirement value" ;
    rdfs:comment "Value of a requirement (e.g., tool name, version)" .

oc:requiresState a owl:ObjectProperty ;
    rdfs:label "requires state" ;
    rdfs:comment "Pre-condition state that must be satisfied before skill execution" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:State .

oc:resolvesIntent a owl:DatatypeProperty ;
    rdfs:label "resolves intent" ;
    rdfs:comment "User intent that this skill can resolve" ;
    rdfs:domain oc:Skill .

oc:severityLevel a owl:DatatypeProperty ;
    rdfs:label "severity level" ;
    rdfs:comment "Must be one of: CRITICAL, HIGH, MEDIUM, LOW" ;
    rdfs:domain oc:KnowledgeNode .

oc:timeout a owl:DatatypeProperty ;
    rdfs:label "timeout" ;
    rdfs:comment "Execution timeout in seconds" ;
    rdfs:domain oc:ExecutionPayload .

oc:yieldsState a owl:ObjectProperty ;
    rdfs:label "yields state" ;
    rdfs:comment "State that results from successful skill execution" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:State .

oc:Attempt a owl:Class ;
    rdfs:label "Attempt" ;
    rdfs:comment "Record of a skill execution attempt, used for negative memory" .

oc:ExecutableSkill a owl:Class ;
    rdfs:label "Executable Skill" ;
    rdfs:comment "A skill with an executable code payload" ;
    rdfs:subClassOf oc:Skill .

oc:enables a owl:ObjectProperty ;
    rdfs:label "enables" ;
    rdfs:comment "Skill enables another skill (inverse of dependsOn)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:extends a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "extends" ;
    rdfs:comment "Skill extends another skill (inheritance)" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill ;
    owl:inverseOf oc:isExtendedBy .

oc:impartsKnowledge a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "imparts knowledge" ;
    rdfs:comment "Links a skill to epistemic knowledge it imparts to the agent" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:KnowledgeNode ;
    rdfs:subPropertyOf oc:inheritsKnowledge .

oc:inheritsKnowledge a owl:ObjectProperty ;
    rdfs:label "inherits knowledge" ;
    owl:propertyChainAxiom ( oc:extends oc:impartsKnowledge ) .

oc:isExtendedBy a owl:ObjectProperty ;
    rdfs:label "is extended by" ;
    rdfs:comment "Inverse of extends" ;
    rdfs:domain oc:Skill ;
    rdfs:range oc:Skill .

oc:Observability a owl:Class ;
    rdfs:label "Observability" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ResilienceTactic a owl:Class ;
    rdfs:label "ResilienceTactic" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ResourceProfile a owl:Class ;
    rdfs:label "ResourceProfile" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:TrustMetric a owl:Class ;
    rdfs:label "TrustMetric" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:CognitiveBoundary a owl:Class ;
    rdfs:label "CognitiveBoundary" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ExecutionPhysics a owl:Class ;
    rdfs:label "ExecutionPhysics" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:LifecycleHook a owl:Class ;
    rdfs:label "LifecycleHook" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:NormativeRule a owl:Class ;
    rdfs:label "NormativeRule" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:SecurityGuardrail a owl:Class ;
    rdfs:label "SecurityGuardrail" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:StrategicInsight a owl:Class ;
    rdfs:label "StrategicInsight" ;
    rdfs:subClassOf oc:KnowledgeNode .

oc:ExecutionPayload a owl:Class ;
    rdfs:label "Execution Payload" ;
    rdfs:comment "Container for executable code and execution metadata" .

oc:KnowledgeNode a owl:Class ;
    rdfs:label "Knowledge Node" ;
    rdfs:comment "Epistemic knowledge imparted by a skill to an agent" .

oc:State a owl:Class ;
    rdfs:label "State" ;
    rdfs:comment "Abstract class representing a system state (precondition, outcome, or failure)" .

oc:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "Base class for all executable skills in the ontology" .

