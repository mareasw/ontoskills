oc:kn_21eaa806 a oc:Idempotency ;
    oc:appliesToContext "When retrying or re-running PDF operations" ;
    oc:directiveContent "PDF merge and split operations are idempotent - running the same operation multiple times produces identical output; however, form filling and annotation operations are NOT idempotent and will layer changes" ;
    oc:hasRationale "Understanding idempotency helps prevent duplicate annotations or unexpected layered modifications" ;
    oc:severityLevel "LOW" .

oc:kn_5705dd03 a oc:PreFlightCheck ;
    oc:appliesToContext "Before filling non-fillable PDF forms" ;
    oc:directiveContent "Create validation images with red/blue bounding boxes and visually inspect them before applying annotations to non-fillable PDFs" ;
    oc:hasRationale "PDF coordinate systems are complex (origin at bottom-left, Y increases upward) and manual bounding box specification without visual validation leads to text appearing in wrong locations" ;
    oc:severityLevel "HIGH" .

oc:kn_8d98b125 a oc:RecoveryTactic ;
    oc:appliesToContext "When encountering corrupted or encrypted PDF errors" ;
    oc:directiveContent "For corrupted PDFs, use qpdf --check and qpdf --fix-qdf to attempt repair; for encrypted PDFs, use pypdf's decrypt() method or qpdf --decrypt" ;
    oc:hasRationale "PDF corruption and encryption are common issues - these tools have specialized repair and decryption capabilities" ;
    oc:severityLevel "MEDIUM" .

oc:kn_92df7d19 a oc:PerformanceProfile ;
    oc:appliesToContext "When processing PDFs larger than 50 pages or 50MB" ;
    oc:directiveContent "For large PDFs, use streaming approaches, process pages in chunks with pypdfium2, or use command-line tools like qpdf --split-pages instead of loading entire documents in memory" ;
    oc:hasRationale "Loading large PDFs entirely in memory causes performance degradation and potential out-of-memory errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b23043c9 a oc:AntiPattern ;
    oc:appliesToContext "When defining bounding boxes for PDF form annotations" ;
    oc:directiveContent "Never modify label and entry bounding boxes to overlap in non-fillable PDF forms; label boxes should only contain static text, entry boxes should only cover input areas" ;
    oc:hasRationale "Overlapping bounding boxes cause text to render incorrectly and can obscure both the label and the entered data" ;
    oc:severityLevel "HIGH" .

oc:kn_e6d3418e a oc:DesignPrinciple ;
    oc:appliesToContext "When selecting PDF processing tools" ;
    oc:directiveContent "Choose the right tool for each operation: pypdf for merging/splitting/rotating, pdfplumber for text/table extraction with layout, reportlab for creation, pdftotext for fast plain text, qpdf for command-line operations and repair" ;
    oc:hasRationale "Each library has different strengths - using the wrong tool results in poor performance, missing features, or corrupted output" ;
    oc:severityLevel "MEDIUM" .

oc:kn_eb82e740 a oc:Heuristic ;
    oc:appliesToContext "When text extraction fails or returns poor results" ;
    oc:directiveContent "Use OCR (pytesseract + pdf2image) as a fallback for text extraction when pdfplumber returns empty or garbled text, indicating a scanned document" ;
    oc:hasRationale "Scanned PDFs contain images rather than text data and require OCR for extraction" ;
    oc:severityLevel "LOW" .

oc:kn_f7473f6e a oc:WorkflowStrategy ;
    oc:appliesToContext "When filling any PDF form" ;
    oc:directiveContent "Always check for fillable form fields using check_fillable_fields.py before attempting to fill a PDF form; use fill_fillable_fields.py for fillable forms and fill_pdf_form_with_annotations.py for non-fillable forms" ;
    oc:hasRationale "Fillable and non-fillable PDFs require completely different approaches - fillable forms have structured field data while non-fillable forms require visual coordinate-based text annotation" ;
    oc:severityLevel "CRITICAL" .

oc:payload_49a660f1e7a50a30 a oc:ExecutionPayload ;
    oc:code """# PDF processing skill execution
# Supports multiple operations based on user intent

# Common imports
from pypdf import PdfReader, PdfWriter
import pdfplumber
from reportlab.lib.pagesizes import letter
from reportlab.pdfgen import canvas
import sys

# Operation routing based on intent
operation = sys.argv[1] if len(sys.argv) > 1 else 'help'

if operation == 'extract_text':
    # Extract text from PDF
    pdf_path = sys.argv[2]
    with pdfplumber.open(pdf_path) as pdf:
        for page in pdf.pages:
            print(page.extract_text())

elif operation == 'merge':
    # Merge multiple PDFs
    output_path = sys.argv[2]
    input_files = sys.argv[3:]
    writer = PdfWriter()
    for pdf_file in input_files:
        reader = PdfReader(pdf_file)
        for page in reader.pages:
            writer.add_page(page)
    with open(output_path, 'wb') as f:
        writer.write(f)

elif operation == 'split':
    # Split PDF into individual pages
    pdf_path = sys.argv[2]
    reader = PdfReader(pdf_path)
    for i, page in enumerate(reader.pages):
        writer = PdfWriter()
        writer.add_page(page)
        with open(f'page_{i+1}.pdf', 'wb') as f:
            writer.write(f)

elif operation == 'create':
    # Create new PDF
    output_path = sys.argv[2]
    c = canvas.Canvas(output_path, pagesize=letter)
    c.drawString(100, 750, 'New PDF Document')
    c.save()

elif operation == 'fill_form_check':
    # Check if PDF has fillable fields
    pdf_path = sys.argv[2]
    reader = PdfReader(pdf_path)
    if reader.get_fields():
        print('Fillable form fields detected')
    else:
        print('No fillable fields; requires visual annotation')

else:
    print('Operations: extract_text, merge, split, create, fill_form_check')""" ;
    oc:executor "python" ;
    oc:timeout 30000 .

