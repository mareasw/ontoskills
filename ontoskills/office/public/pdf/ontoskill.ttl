oc:payload_49a660f1e7a50a30 a oc:ExecutionPayload ;
    oc:code """# PDF processing toolkit execution
from pypdf import PdfReader, PdfWriter
import pdfplumber
from reportlab.lib.pagesizes import letter
from reportlab.pdfgen import canvas
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer
from reportlab.lib.styles import getSampleStyleSheet

# Core operations available:
# - Read/Write PDFs (pypdf)
# - Extract text/tables (pdfplumber)
# - Create PDFs (reportlab)
# - Merge/Split PDFs (pypdf)
# - Fill forms (pypdf + custom scripts)
# - Convert to images (pdf2image)
# - OCR scanned PDFs (pytesseract + pdf2image)

# Command-line tools:
# - qpdf: merge, split, rotate, encrypt
# - pdftotext: extract text
# - pdfimages: extract images

# Form filling workflow:
# 1. Check if fillable: python scripts/check_fillable_fields.py <pdf>
# 2. Extract field info: python scripts/extract_form_field_info.py <pdf> <json>
# 3. Fill fields: python scripts/fill_fillable_fields.py <pdf> <json> <output>
# Or for non-fillable: python scripts/fill_pdf_form_with_annotations.py <pdf> <json> <output>""" ;
    oc:executor "python" .

