oc:payload_49a660f1e7a50a30 a oc:ExecutionPayload ;
    oc:code """# PDF Processing execution framework
# Supports: extraction, creation, merging, splitting, form filling
import subprocess
from pathlib import Path

# Use appropriate library based on operation type
# - pypdf for merge/split/rotate
# - pdfplumber for text/table extraction
# - reportlab for creation
# - Custom scripts for form filling (see scripts/)
""" ;
    oc:executor "python" .

