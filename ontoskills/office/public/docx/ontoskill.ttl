        oc:req_5c2a11c1,
        oc:req_7cf00395,
        oc:req_bbe906e4,
        oc:req_c2789dcc ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "add tracked changes",
        "analyze word document",
        "convert docx to images",
        "convert docx to markdown",
        "create word document",
        "edit word document",
        "extract text from docx",
        "review document" ;
    oc:yieldsState oc:DocumentCreated,
        oc:DocumentModified,
        oc:DocumentValidated,
