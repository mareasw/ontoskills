    dcterms:identifier "docx" ;
    skos:broader "Document processor" ;
    prov:wasDerivedFrom "/Users/marcello/Developer/Marea/ontoclaw/skills/office/public/docx" .

oc:payload_9edb0243108eb53f a oc:ExecutionPayload ;
    oc:code """# Multiple workflows available:
# 1. Create new: Use docx-js (JavaScript)
# 2. Edit existing: Use Document library (Python)
# 3. Extract text: pandoc --track-changes=all file.docx -o output.md
# 4. Unpack: python ooxml/scripts/unpack.py file.docx output_dir
# 5. Pack: python ooxml/scripts/pack.py input_dir file.docx
# 6. Convert: soffice --headless --convert-to pdf file.docx && pdftoppm -jpeg file.pdf page""" ;
    oc:executor "python" ;
    oc:timeout 30000 .

