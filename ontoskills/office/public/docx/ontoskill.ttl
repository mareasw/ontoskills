oc:payload_9edb0243108eb53f a oc:ExecutionPayload ;
    oc:code """# DOCX skill provides multiple execution paths depending on task:

# 1. CREATE NEW DOCUMENT: Use docx-js (JavaScript)
# const { Document, Packer, Paragraph, TextRun } = require('docx');
# const doc = new Document({ sections: [{ children: [/* content */] }] });
# Packer.toBuffer(doc).then(buffer => fs.writeFileSync('doc.docx', buffer));

# 2. EXTRACT TEXT: Use pandoc (Shell)
# pandoc --track-changes=all document.docx -o output.md

# 3. EDIT DOCUMENT: Use Document library (Python)
from skills.docx.scripts.document import Document

# Unpack, edit, pack workflow:
# python ooxml/scripts/unpack.py document.docx unpacked/

doc = Document('unpacked', track_revisions=True)

# Add tracked changes
node = doc['word/document.xml'].get_node(tag='w:r', contains='old text')
doc['word/document.xml'].replace_node(node, 
    '<w:del><w:r><w:delText>old text</w:delText></w:r></w:del>'
    '<w:ins><w:r><w:t>new text</w:t></w:r></w:ins>')

# Add comments
doc.add_comment(start=node, end=node, text='Review this change')

# Save with validation
doc.save()

# Repack:
# python ooxml/scripts/pack.py unpacked/ modified.docx

# 4. CONVERT TO IMAGES (Shell):
# soffice --headless --convert-to pdf document.docx
# pdftoppm -jpeg -r 150 document.pdf page""" ;
    oc:executor "python" ;
    oc:timeout 30000 .

