oc:kn_34393353 a oc:Heuristic ;
    oc:appliesToContext "When implementing multiple tracked changes in a document" ;
    oc:directiveContent "Group related tracked changes into batches of 3-10 changes to balance efficiency with debuggability" ;
    oc:hasRationale "Large batches are hard to debug when errors occur, while single-change batches are inefficient - 3-10 provides the optimal balance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_61a26f16 a oc:AntiPattern ;
    oc:appliesToContext "When implementing tracked changes in any document" ;
    oc:directiveContent "Never mark unchanged text in tracked changes - only wrap the actual changed portions in <w:del> and <w:ins> tags" ;
    oc:hasRationale "Marking unchanged text makes edits unprofessional, harder to review, and violates the principle of minimal precise edits" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6988cde4 a oc:AntiPattern ;
    oc:appliesToContext "When creating documents with docx-js library" ;
    oc:directiveContent "NEVER use \\n for line breaks in docx-js - always use separate Paragraph elements for each line" ;
    oc:hasRationale "Using \\n creates invalid XML structure that can corrupt the document - Paragraph elements are the proper OOXML structure" ;
    oc:severityLevel "CRITICAL" .

oc:kn_70679d67 a oc:Idempotency ;
    oc:appliesToContext "When re-running document modification scripts" ;
    oc:directiveContent "Document operations are not idempotent - running the same script twice will create duplicate tracked changes or comments" ;
    oc:hasRationale "Each execution adds new tracked change markers and comment IDs without checking for existing ones, requiring careful version control" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7ff2c4f5 a oc:Constraint ;
    oc:appliesToContext "Before creating or editing any document" ;
    oc:directiveContent "ALWAYS read the full documentation file (docx-js.md or ooxml.md) completely before starting - never set range limits when reading" ;
    oc:hasRationale "Critical formatting rules and common pitfalls are distributed throughout the documentation - partial reads lead to corrupted files or rendering issues" ;
    oc:severityLevel "CRITICAL" .

oc:kn_85e8e385 a oc:DesignPrinciple ;
    oc:appliesToContext "When starting any DOCX task" ;
    oc:directiveContent "Choose the correct workflow based on task type: use docx-js for new documents, Document library for editing existing documents, and redlining workflow for reviewing others' documents" ;
    oc:hasRationale "Using the wrong workflow causes inefficiency and potential data loss - docx-js is optimal for creation, Document library preserves existing structure during edits, redlining ensures proper tracked changes" ;
    oc:severityLevel "HIGH" .

oc:kn_8775c31c a oc:KnownIssue ;
    oc:appliesToContext "When adding page breaks to documents" ;
    oc:directiveContent "PageBreak must ALWAYS be inside a Paragraph - standalone PageBreak creates invalid XML that Word cannot open" ;
    oc:hasRationale "The docx library generates invalid XML when PageBreak is used standalone, causing Word to fail to open the file" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c57605dc a oc:PreFlightCheck ;
    oc:appliesToContext "Before implementing tracked changes or edits" ;
    oc:directiveContent "Always grep word/document.xml to verify text content and line numbers immediately before writing modification scripts" ;
    oc:hasRationale "Line numbers change after each script run, and text may be split across XML elements differently than expected" ;
    oc:severityLevel "HIGH" .

oc:kn_cac22774 a oc:Heuristic ;
    oc:appliesToContext "When modifying documents created by other authors" ;
    oc:directiveContent "When editing others' documents, always use the redlining workflow with tracked changes rather than direct edits" ;
    oc:hasRationale "Redlining preserves audit trails, allows for review and rejection of changes, and maintains professional document collaboration standards" ;
    oc:severityLevel "HIGH" .

oc:kn_ffb6c00e a oc:Constraint ;
    oc:appliesToContext "When applying background colors to table cells" ;
    oc:directiveContent "Always use ShadingType.CLEAR for table cell shading - never use ShadingType.SOLID which causes black backgrounds" ;
    oc:hasRationale "ShadingType.SOLID renders incorrectly in Word causing black cells instead of the intended color" ;
    oc:severityLevel "HIGH" .

oc:payload_9edb0243108eb53f a oc:ExecutionPayload ;
    oc:code """# DOCX operations require choosing the appropriate workflow:
# 1. Creating new documents: Use docx-js (JavaScript/TypeScript)
# 2. Editing existing documents: Use Document library (Python)
# 3. Redlining/review: Use tracked changes workflow

# For Python editing workflow:
from skills.docx.scripts.document import Document

# Initialize with tracked changes support
doc = Document('unpacked_directory', track_revisions=True)

# Find and modify content
node = doc["word/document.xml"].get_node(tag="w:r", contains="target text")
doc["word/document.xml"].replace_node(node, '<w:del><w:r><w:delText>old</w:delText></w:r></w:del><w:ins><w:r><w:t>new</w:t></w:r></w:ins>')

# Add comments
start_node = doc["word/document.xml"].get_node(tag="w:del", attrs={"w:id": "1"})
end_node = doc["word/document.xml"].get_node(tag="w:ins", attrs={"w:id": "2"})
doc.add_comment(start=start_node, end=end_node, text="Explanation")

# Save with validation
doc.save()  # Validates by default""" ;
    oc:executor "python" ;
    oc:timeout 30000 .

