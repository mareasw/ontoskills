oc:kn_070d0c6c a oc:DesignPrinciple ;
    oc:appliesToContext "When building financial models" ;
    oc:directiveContent "Place ALL assumptions (growth rates, margins, multiples) in separate assumption cells and reference them in formulas. Use =B5*(1+$B$6) instead of =B5*1.05." ;
    oc:hasRationale "Separated assumptions make models auditable, allow easy scenario analysis, and prevent hardcoded values from being scattered throughout the model" ;
    oc:severityLevel "HIGH" .

oc:kn_073afa6b a oc:Heuristic ;
    oc:appliesToContext "When choosing between pandas and openpyxl" ;
    oc:directiveContent "Use pandas for data analysis, bulk operations, and simple data export. Use openpyxl for complex formatting, formulas, and Excel-specific features like cell styles." ;
    oc:hasRationale "Each library has distinct strengths; pandas excels at data manipulation while openpyxl preserves Excel-specific features" ;
    oc:severityLevel "MEDIUM" .

oc:kn_296d22d5 a oc:AntiPattern ;
    oc:appliesToContext "When reading Excel files with openpyxl" ;
    oc:directiveContent "Never load a workbook with data_only=True and save it - this permanently replaces formulas with their calculated values, destroying the formula logic." ;
    oc:hasRationale "data_only=True reads values, but saving overwrites formulas permanently, making the spreadsheet static and losing computational logic" ;
    oc:severityLevel "CRITICAL" .

oc:kn_31613549 a oc:Constraint ;
    oc:appliesToContext "When modifying existing Excel templates" ;
    oc:directiveContent "Existing template formatting, styles, and conventions ALWAYS override standard guidelines. Study and match existing patterns before applying new formatting." ;
    oc:hasRationale "Consistency with established patterns is more important than applying generic standards; template conventions reflect business logic and user expectations" ;
    oc:severityLevel "HIGH" .

oc:kn_3d2f1b48 a oc:RecoveryTactic ;
    oc:appliesToContext "When formula errors are detected" ;
    oc:directiveContent "If recalc.py reports errors, check error_summary for specific types: #REF! (invalid references), #DIV/0! (division by zero), #VALUE! (wrong data type). Fix identified cells and run recalc.py again." ;
    oc:hasRationale "Systematic error categorization enables targeted fixes; iterative recalculation ensures all errors are resolved" ;
    oc:severityLevel "HIGH" .

oc:kn_5c1ac75c a oc:PreFlightCheck ;
    oc:appliesToContext "Before creating formulas in bulk" ;
    oc:directiveContent "Before building formulas, test 2-3 sample cell references to verify correct values, confirm column mapping (column 64 = BL not BK), and remember Excel rows are 1-indexed." ;
    oc:hasRationale "Early verification prevents systematic errors across many cells and catches off-by-one errors before they propagate" ;
    oc:severityLevel "HIGH" .

oc:kn_75b57d14 a oc:PostFlightValidation ;
    oc:appliesToContext "After running recalc.py on any Excel file" ;
    oc:directiveContent "After recalc.py execution, check the JSON output for status='errors_found' and review error_summary for specific error types (#REF!, #DIV/0!, etc.) and their locations. Fix and recalculate." ;
    oc:hasRationale "The recalc output provides precise error locations enabling systematic correction; ignoring errors results in broken spreadsheets" ;
    oc:severityLevel "HIGH" .

oc:kn_8d3f4460 a oc:Standard ;
    oc:appliesToContext "When creating or modifying any Excel file" ;
    oc:directiveContent "Every Excel model MUST be delivered with ZERO formula errors (#REF!, #DIV/0!, #VALUE!, #N/A, #NAME?). Run recalc.py to detect and fix all errors before delivery." ;
    oc:hasRationale "Formula errors break spreadsheet functionality and undermine user trust in the model's accuracy" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9f8ea79e a oc:KnownIssue ;
    oc:appliesToContext "After creating or modifying Excel files with openpyxl" ;
    oc:directiveContent "Files created/modified by openpyxl contain formulas as strings but not calculated values - cells show #REF! or empty until recalc.py is run with LibreOffice." ;
    oc:hasRationale "openpyxl writes formula strings without evaluation; LibreOffice provides the calculation engine needed to compute values" ;
    oc:severityLevel "HIGH" .

oc:kn_e82383ff a oc:Standard ;
    oc:appliesToContext "When adding any calculation to an Excel file" ;
    oc:directiveContent "Always use Excel formulas instead of hardcoded calculated values. Use =SUM(B2:B9) instead of hardcoding the result 5000." ;
    oc:hasRationale "Formulas keep spreadsheets dynamic and updateable when source data changes, maintaining the spreadsheet's computational integrity" ;
    oc:severityLevel "CRITICAL" .

oc:kn_eeeca62e a oc:WorkflowStrategy ;
    oc:appliesToContext "When creating financial models" ;
    oc:directiveContent "Follow the financial modeling color coding standards: Blue text for hardcoded inputs, Black for formulas, Green for internal worksheet links, Red for external file links, Yellow background for key assumptions." ;
    oc:hasRationale "Color coding creates visual distinction between input types, making models easier to audit and understand" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef0297b0 a oc:Idempotency ;
    oc:appliesToContext "When using the recalc.py script" ;
    oc:directiveContent "Running recalc.py multiple times on the same file is safe - it recalculates formulas and checks for errors without side effects beyond updating calculated values." ;
    oc:hasRationale "Idempotent operation allows safe re-execution during debugging without risk of data corruption" ;
    oc:severityLevel "LOW" .

oc:payload_85daf4eef0ab9248 a oc:ExecutionPayload ;
    oc:code """# Library selection based on task:
# - pandas: data analysis, bulk operations, simple data export
# - openpyxl: complex formatting, formulas, Excel-specific features

# Common workflow:
# 1. Choose tool (pandas for data, openpyxl for formulas/formatting)
# 2. Create/Load workbook
# 3. Modify data, formulas, and formatting
# 4. Save to file
# 5. Recalculate formulas using recalc.py
# 6. Verify and fix any errors

# IMPORTANT: Always use Excel formulas instead of hardcoded values
# WRONG: sheet['B10'] = total (hardcoded)
# RIGHT: sheet['B10'] = '=SUM(B2:B9)' (dynamic formula)

# After creating/modifying files with formulas, always run:
# python recalc.py output.xlsx [timeout_seconds]
# This returns JSON with error details and formula counts""" ;
    oc:executor "python" ;
    oc:timeout 60 .

oc:req_111f766b a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "LibreOffice" .

oc:req_47a90164 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "openpyxl" .

oc:req_746aacc9 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "pandas" .

oc:req_7e9ca2f5 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "python" .

