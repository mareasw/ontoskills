    prov:wasDerivedFrom "/Users/marcello/Developer/Marea/ontoclaw/skills/office/public/xlsx" .

oc:payload_85daf4eef0ab9248 a oc:ExecutionPayload ;
    oc:code """# Create new spreadsheet
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill

wb = Workbook()
sheet = wb.active
sheet['A1'] = 'Data'
sheet['B1'] = 'Value'
sheet['B2'] = '=SUM(B3:B10)'
wb.save('output.xlsx')

# Recalculate formulas
import subprocess
result = subprocess.run(['python', 'recalc.py', 'output.xlsx'], capture_output=True, text=True)""" ;
    oc:executor "python" ;
    oc:timeout 60 .

