oc:payload_85daf4eef0ab9248 a oc:ExecutionPayload ;
    oc:code """# Main operations via openpyxl and pandas
from openpyxl import Workbook, load_workbook
import pandas as pd

# Creation workflow
wb = Workbook()
ws = wb.active
ws['A1'] = 'Value'
ws['B1'] = '=SUM(A2:A10)'
wb.save('output.xlsx')

# Editing workflow
wb = load_workbook('existing.xlsx')
ws = wb.active
ws['A1'] = 'New Value'
wb.save('modified.xlsx')

# Analysis workflow
df = pd.read_excel('data.xlsx')
print(df.describe())

# Recalculation workflow
import subprocess
result = subprocess.run(['python', 'recalc.py', 'output.xlsx'], capture_output=True, text=True)""" ;
    oc:executor "python" ;
    oc:timeout 60 .

