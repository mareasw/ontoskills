oc:kn_73c6520f a oc:PreFlightCheck ;
    oc:appliesToContext "When editing existing Office documents" ;
    oc:directiveContent "For OOXML formats (PPTX, DOCX), always unpack, edit XML, validate, then pack. Validation is mandatory before packing." ;
    oc:hasRationale "Ensures document integrity and catches structural errors before final output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7bad73e5 a oc:WorkflowStrategy ;
    oc:appliesToContext "When creating PowerPoint presentations" ;
    oc:directiveContent "For PPTX: use html2pptx for scratch creation, template workflow for existing designs. Always generate thumbnails for visual validation." ;
    oc:hasRationale "Different workflows optimize for different starting points. Visual validation catches layout issues early" ;
    oc:severityLevel "HIGH" .

oc:kn_8523e8e3 a oc:Heuristic ;
    oc:appliesToContext "When selecting tools for document operations" ;
    oc:directiveContent "Use pandas for data analysis and bulk operations, openpyxl for formulas/formatting, and pypdf/pdfplumber for PDF text extraction." ;
    oc:hasRationale "Each library has different strengths - choosing the right one ensures efficiency and correctness" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8b9940c9 a oc:WorkflowStrategy ;
    oc:appliesToContext "When creating any files using skill workflows" ;
    oc:directiveContent "Use outputs/<document-name>/ directory for all intermediate and final files. Never write to repository root or public/ directories." ;
    oc:hasRationale "Maintains clean working directory, enables automation, and follows gitignore conventions" ;
    oc:severityLevel "HIGH" .

oc:kn_8d6a7e72 a oc:Idempotency ;
    oc:appliesToContext "When running document generation scripts" ;
    oc:directiveContent "Document workflows are NOT idempotent - repeated execution may create duplicate outputs or overwrite files." ;
    oc:hasRationale "Scripts write to fixed output paths. Use unique document names for different versions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8e7fbfeb a oc:Constraint ;
    oc:appliesToContext "When creating or modifying Excel spreadsheets" ;
    oc:directiveContent "Excel models must have ZERO formula errors. All zeros must be formatted as '-'. Years as text, not numbers." ;
    oc:hasRationale "Financial modeling standards require error-free formulas and proper formatting for professional use" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8f5ac66e a oc:RecoveryTactic ;
    oc:appliesToContext "When OOXML validation fails" ;
    oc:directiveContent "If validation fails after OOXML editing, check validation script output for specific error locations and fix before packing." ;
    oc:hasRationale "Validation errors indicate structural problems that will corrupt the document if not fixed" ;
    oc:severityLevel "CRITICAL" .

oc:kn_96ee7873 a oc:DesignPrinciple ;
    oc:appliesToContext "Before any document manipulation operation" ;
    oc:directiveContent "Always check if a skill exists for a task before writing custom code. Read SKILL.md files completely without range limits." ;
    oc:hasRationale "Prevents reinventing workflows that already exist and ensures consistency with established patterns" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a4c78486 a oc:AntiPattern ;
    oc:appliesToContext "When working with spreadsheets or PDFs" ;
    oc:directiveContent "Never hardcode calculated values in Excel - use Excel formulas instead. Never use pypdf for PDF operations (use pdfplumber instead)." ;
    oc:hasRationale "Hardcoded values break spreadsheet dynamism. pypdf lacks features needed for proper PDF manipulation" ;
    oc:severityLevel "HIGH" .

oc:kn_de0cc542 a oc:AssumptionBoundary ;
    oc:appliesToContext "Before using system tools for conversion or extraction" ;
    oc:directiveContent "Assumes LibreOffice, Poppler, and Pandoc are pre-installed for advanced operations. Python venv and Node modules must be set up." ;
    oc:hasRationale "System dependencies are required but may not be available in all environments" ;
    oc:severityLevel "MEDIUM" .

