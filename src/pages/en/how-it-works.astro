---
import LandingLayout from '../../layouts/LandingLayout.astro';
import Header from '../../components/landing/Header.astro';
import Footer from '../../components/landing/Footer.astro';
import Button from '../../components/ui/Button.astro';

const steps = [
  {
    number: 1,
    title: 'SKILL.md',
    subtitle: 'Human-authored',
    description: 'Skills are authored in Markdown with YAML frontmatter. Developers write clear instructions, define intents, and structure content that AI agents can understand and execute.',
    bullets: [
      'YAML frontmatter for metadata',
      'Markdown body for instructions',
      'Version-controlled with your code',
      'Human-readable, AI-friendly'
    ],
    code: `---
name: tdd-workflow
description: Test-driven development
intents:
  - write_tests_first
---

## Instructions
1. Write the test first
2. Run the test (it fails)
3. Write minimal code
4. Run the test (it passes)
5. Refactor`
  },
  {
    number: 2,
    title: 'OntoCore',
    subtitle: 'The Compiler',
    description: 'OntoCore compiles SKILL.md files into OWL 2 DL ontologies. The compiler validates structure, extracts semantic relationships, and generates machine-readable RDF triples.',
    bullets: [
      'Parses and validates SKILL.md',
      'Extracts semantic relationships',
      'Generates OWL 2 DL ontology',
      'SHACL validation built-in'
    ],
    code: `$ npx ontoskills compile

  Parsing tdd-workflow/SKILL.md...
  Validating structure...
  Generating ontology...
  Writing triples...

  ✓ Compiled to ontoskills/tdd-workflow.ttl`
  },
  {
    number: 3,
    title: '.ttl Files',
    subtitle: 'The Ontology',
    description: 'The compiled Turtle (.ttl) files contain the ontology — a formal representation of skills, intents, and their relationships using RDF triples and OWL semantics.',
    bullets: [
      'Standard RDF Turtle format',
      'OWL 2 DL definitions',
      'SPARQL-queryable graph',
      'Semantic skill relationships'
    ],
    code: `@prefix oc: <https://ontoskills.dev/ns#> .

oc:tdd-workflow a oc:Skill ;
  oc:name "tdd-workflow" ;
  oc:description "Test-driven dev" ;
  oc:resolvesIntent "write_tests_first" ;
  oc:hasStep oc:write-test,
             oc:run-test,
             oc:implement .`
  },
  {
    number: 4,
    title: 'OntoMCP',
    subtitle: 'The Runtime',
    description: 'OntoMCP is the Rust-based MCP runtime that loads ontologies and serves skill queries to AI agents through the Model Context Protocol with sub-millisecond response times.',
    bullets: [
      'Native Rust performance',
      'MCP protocol implementation',
      'Sub-millisecond SPARQL',
      'Intent-based discovery'
    ],
    code: `# Search by intent
search_intents("create_pdf")
  → pdf-generator
  → report-exporter

# Get skill context
get_skill("pdf-generator")
  → { name, description, instructions }`
  }
];
---

<LandingLayout title="How it Works - OntoSkills">
  <Header lang="en" />
  <main>
    <!-- Hero Section -->
    <section class="pt-20 pb-8">
      <div class="section-shell">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Pipeline
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary mb-6 tracking-tight">
            How it <span class="text-cyan-400">Works</span>
          </h1>
          <p class="text-xl text-text-secondary max-w-2xl mx-auto">
            From SKILL.md to deterministic execution in 4 simple steps
          </p>
        </div>
      </div>
    </section>

    <!-- Pipeline Overview - Horizontal on desktop, vertical on mobile -->
    <section class="pb-12 overflow-x-auto">
      <div class="section-shell">
        <div class="flex flex-col lg:flex-row items-center justify-center gap-2 lg:gap-0 min-w-max lg:min-w-0">
          {steps.map((step, index) => (
            <>
              <div class="pipeline-step flex flex-col items-center text-center px-4 lg:px-6 py-4">
                <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border border-cyan-500/30 flex items-center justify-center text-cyan-400 mb-3 relative">
                  <span class="text-xl font-bold">{step.number}</span>
                  <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-cyan-500 text-[10px] font-bold text-black flex items-center justify-center">
                    {index + 1}
                  </div>
                </div>
                <div class="font-semibold text-text-primary text-sm whitespace-nowrap">{step.title}</div>
                <div class="text-xs text-text-muted whitespace-nowrap">{step.subtitle}</div>
              </div>
              {index < steps.length - 1 && (
                <div class="pipeline-arrow hidden lg:flex items-center text-cyan-500/40">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              )}
              {index < steps.length - 1 && (
                <div class="lg:hidden flex items-center text-cyan-500/40 my-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                  </svg>
                </div>
              )}
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- Detailed Steps with Alternating Layout -->
    <section class="pb-20">
      <div class="section-shell">
        <div class="space-y-24 lg:space-y-32">
          {steps.map((step, index) => (
            <div class="step-section" id={`step-${step.number}`}>
              <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                <!-- Content Column -->
                <div class={`space-y-5 ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
                  <!-- Step Number Badge -->
                  <div class="flex items-center gap-4">
                    <div class="flex items-center gap-3">
                      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border border-cyan-500/30 flex items-center justify-center">
                        <span class="text-xl font-bold text-cyan-400">{step.number}</span>
                      </div>
                      <div>
                        <h2 class="text-2xl sm:text-3xl font-bold text-text-primary">{step.title}</h2>
                        <p class="text-sm text-cyan-400 font-medium">{step.subtitle}</p>
                      </div>
                    </div>
                  </div>

                  <p class="text-text-secondary leading-relaxed text-lg">
                    {step.description}
                  </p>

                  <ul class="space-y-3">
                    {step.bullets.map((bullet) => (
                      <li class="flex items-center gap-3">
                        <div class="w-5 h-5 rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center flex-shrink-0">
                          <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <span class="text-text-secondary">{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Code Column -->
                <div class={` ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
                  <div class="relative">
                    <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500/20 to-blue-500/20 rounded-2xl blur-xl opacity-50"></div>
                    <div class="relative bg-bg-elevated border border-white/10 rounded-2xl overflow-hidden">
                      <!-- Code Header -->
                      <div class="flex items-center justify-between px-4 py-3 border-b border-white/5 bg-black/20">
                        <div class="flex items-center gap-2">
                          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                          <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                          <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
                        </div>
                        <span class="text-xs text-text-muted font-mono">{step.number === 1 ? 'SKILL.md' : step.number === 2 ? 'terminal' : step.number === 3 ? 'output.ttl' : 'mcp-query'}</span>
                      </div>
                      <!-- Code Content -->
                      <div class="p-4 sm:p-6 overflow-x-auto">
                        <pre class="text-sm font-mono text-text-secondary whitespace-pre-wrap"><code>{step.code}</code></pre>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="section-shell">
        <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-cyan-500/5 via-bg-elevated to-blue-500/5 p-8 sm:p-12 lg:p-16">
          <!-- Background decoration -->
          <div class="absolute top-0 right-0 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

          <div class="relative text-center">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-4 tracking-tight">
              Ready to compile your first skill?
            </h2>
            <p class="text-text-secondary mb-8 max-w-xl mx-auto text-lg">
              Get started with OntoSkills in minutes. Write your first SKILL.md, compile it to an ontology, and query it through MCP.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <Button href="/en/getting-started/" size="lg">Get Started</Button>
              <Button href="/ontostore/" variant="secondary" size="lg">Browse OntoStore</Button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</LandingLayout>

<style>
  /* Smooth scroll */
  html {
    scroll-behavior: smooth;
  }

  /* Pipeline step hover */
  .pipeline-step {
    transition: transform 0.2s ease;
  }

  .pipeline-step:hover {
    transform: translateY(-2px);
  }

  /* Step sections animation */
  .step-section {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.6s ease forwards;
  }

  .step-section:nth-child(1) { animation-delay: 0.1s; }
  .step-section:nth-child(2) { animation-delay: 0.2s; }
  .step-section:nth-child(3) { animation-delay: 0.3s; }
  .step-section:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .step-section {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .pipeline-step:hover {
      transform: none;
    }
  }

  /* Code block scroll indicator on mobile */
  @media (max-width: 640px) {
    pre {
      font-size: 0.75rem;
    }
  }
</style>
