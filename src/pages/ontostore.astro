---
import LandingLayout from '../layouts/LandingLayout.astro';
import Header from '../components/landing/Header.astro';
import Footer from '../components/landing/Footer.astro';
import OntoStore from '../components/store/OntoStore.astro';
---

<LandingLayout
  title="OntoStore — Browse Ontological Skills"
  description="Browse verified ontological skills. Search by intent, copy install commands, one-line setup."
>
  <Header lang="en" />
  <main class="pt-8 pb-20">
    <div class="section-shell">
      <!-- Hero -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 border border-cyan-500/30 flex items-center justify-center">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-medium tracking-wider uppercase text-cyan-400">Official Registry</span>
            <h1 class="text-3xl sm:text-4xl font-bold text-text-primary">OntoStore</h1>
          </div>
        </div>
        <p class="text-lg text-text-secondary max-w-2xl mb-6">
          Browse ontological skills from the official registry. Search by intent, name, or description.
          Copy install commands and get started in seconds.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="https://github.com/mareasw/ontostore" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
          <span class="text-text-muted">•</span>
          <a href="/en/authoring/" class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            Publish a skill
          </a>
        </div>
      </div>

      <!-- Store Component -->
      <OntoStore showHeader={false} lang="en" />
    </div>
  </main>
  <Footer lang="en" />
</LandingLayout>
