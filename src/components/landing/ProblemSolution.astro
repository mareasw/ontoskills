---
import Button from '../ui/Button.astro';
---

<section class="py-20 bg-bg-secondary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Problem -->
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-text-primary">
          The <span class="text-red-400">Determinism</span> Problem
        </h2>
        <p class="text-text-muted leading-relaxed">
          LLMs are inherently non-deterministic. The same query can yield different results,
          and reasoning about skill relationships requires reading entire documents.
        </p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <span class="text-red-400 mt-1 flex-shrink-0">✗</span>
            <span class="text-text-muted">
              <strong class="text-text-primary">Context rot</strong> — Loading 50+ SKILL.md files to find one capability
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-400 mt-1 flex-shrink-0">✗</span>
            <span class="text-text-muted">
              <strong class="text-text-primary">Hallucinations</strong> — Information scattered across files leads to errors
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-red-400 mt-1 flex-shrink-0">✗</span>
            <span class="text-text-muted">
              <strong class="text-text-primary">No verifiable structure</strong> — Skill relationships remain ambiguous
            </span>
          </li>
        </ul>
      </div>

      <!-- Solution -->
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-text-primary">
          The <span class="gradient-text">OntoClaw</span> Solution
        </h2>
        <p class="text-text-muted leading-relaxed">
          OntoClaw transforms unstructured skill definitions into formal, queryable
          knowledge graphs using Description Logics (OWL 2).
        </p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <span class="text-accent-mint mt-1 flex-shrink-0">✓</span>
            <span class="text-text-muted">
              <strong class="text-text-primary">Decidable reasoning</strong> — OWL 2 DL with transitive, symmetric, inverse properties
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-mint mt-1 flex-shrink-0">✓</span>
            <span class="text-text-muted">
              <strong class="text-text-primary">SPARQL queries</strong> — O(1) indexed lookup vs O(n) text scanning
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-mint mt-1 flex-shrink-0">✓</span>
            <span class="text-text-muted">
              <strong class="text-text-primary">Formal semantics</strong> — No ambiguity in skill relationships
            </span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
