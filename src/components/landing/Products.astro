---
import { type Lang, translations, defaultLang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = translations.products[lang];

const icons = {
  OntoCore: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>`,
  OntoStore: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>`,
  OntoMCP: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`
};

const subtitles = {
  en: { OntoCore: 'The Compiler', OntoStore: 'The Store', OntoMCP: 'The Bridge' },
  zh: { OntoCore: '编译器', OntoStore: '商店', OntoMCP: '桥接器' }
};
---

<section id="products" class="py-20 border-b border-white/10">
  <div class="section-shell">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        {t.title}
      </h2>
      <p class="text-lg text-text-secondary">
        {t.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {t.items.map((product) => (
        <a
          href={product.link}
          class="product-card group border border-white/10 bg-bg-elevated rounded-2xl p-6 transition-all duration-200 hover:-translate-y-1 hover:border-cyan-500/30 hover:bg-white/5"
        >
          <div class="flex items-center mb-4">
            <div class="text-cyan-400 mr-3" set:html={icons[product.name as keyof typeof icons]} />
            <div class="flex-1">
              <h3 class="text-xl font-bold text-text-primary group-hover:text-cyan-400 transition-colors">
                {product.name}
              </h3>
              <p class="text-sm text-cyan-400 font-medium">{subtitles[lang][product.name as keyof typeof subtitles['en']]}</p>
            </div>
          </div>

          <p class="text-text-muted text-sm leading-relaxed mb-4">
            {product.description}
          </p>

          <div class="mt-auto space-y-2">
            {product.features.map((feature) => (
              <div class="flex items-center text-sm text-text-secondary">
                <svg class="w-4 h-4 mr-2 text-cyan-400 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                {feature}
              </div>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-mint), var(--accent-aqua));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .product-card:hover::before {
    opacity: 1;
  }

  .product-card::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 50% 0%, rgba(125, 211, 252, 0.03) 0%, transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .product-card:hover::after {
    opacity: 1;
  }
</style>
