---
const steps = [
  { label: 'Discover', icon: '🔎', description: 'store search' },
  { label: 'Install', icon: '⬇️', description: 'compiled skill download' },
  { label: 'Query', icon: '🛰️', description: 'MCP context retrieval' },
  { label: 'Manage', icon: '🟢', description: 'optional enable/disable' },
  { label: 'Compile', icon: '⚙️', description: 'custom SKILL.md sources' }
];
---

<section class="py-20">
  <div class="section-shell">
    <div class="text-center mb-12">
      <div class="section-kicker mx-auto mb-4">Lifecycle</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        How It <span class="gradient-text">Works</span>
      </h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        From store discovery to local compilation in five steps.
      </p>
    </div>

    <div class="glass-panel rounded-[2rem] p-6">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-2">
      {steps.map((step, index) => (
        <div class="flex items-center">
          <div class="flex flex-col items-center text-center px-4 md:px-6">
            <div class="w-16 h-16 rounded-full bg-white/6 border border-white/12 flex items-center justify-center text-2xl mb-3">
              {step.icon}
            </div>
            <div class="font-semibold text-text-primary mb-1">{step.label}</div>
            <div class="text-sm text-text-muted font-mono">{step.description}</div>
          </div>
          {index < steps.length - 1 && (
            <div class="hidden md:flex items-center text-accent-cyan text-2xl mx-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
          {index < steps.length - 1 && (
            <div class="md:hidden text-accent-cyan text-2xl my-2">
              <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </div>
          )}
        </div>
      ))}
      </div>
    </div>
  </div>
</section>
