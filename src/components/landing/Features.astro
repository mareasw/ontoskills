---
import Card from '../ui/Card.astro';

const features = [
  {
    title: 'Official Store',
    description: 'Published compiled skills are discoverable by qualified id and versioned in a public store.',
    icon: '🗂️'
  },
  {
    title: 'Managed CLI',
    description: 'The ontoskills command installs, updates, enables, disables, and removes product components.',
    icon: '🧭'
  },
  {
    title: 'Remote Install',
    description: 'Install a single compiled skill from the store, auto-enabled and ready to query.',
    icon: '⬇️'
  },
  {
    title: 'Runtime MCP',
    description: 'OntoMCP loads the enabled ontology set and serves package-aware context through a small tool surface.',
    icon: '🛰️'
  },
  {
    title: 'Compiler Workflow',
    description: 'OntoCore turns raw SKILL.md sources into validated ontologies when you need custom skills.',
    icon: '⚙️'
  },
  {
    title: 'Deterministic Resolution',
    description: 'Qualified ids, provenance, and explicit enable/disable state keep lookups predictable.',
    icon: '🔒'
  }
];
---

<section id="features" class="py-20">
  <div class="section-shell">
    <div class="text-center mb-12">
      <div class="section-kicker mx-auto mb-4">Product surface</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        Key <span class="gradient-text">Capabilities</span>
      </h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        Everything you need to ship deterministic, queryable skill ontologies without gluing multiple tools together.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <Card
          title={feature.title}
          description={feature.description}
          icon={feature.icon}
        />
      ))}
    </div>
  </div>
</section>
