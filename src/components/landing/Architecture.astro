---

const mermaidCode = `flowchart TB
    subgraph Input["📥 Input"]
        SKILL[SKILL.md<br/>Natural Language]
    end

    subgraph Extraction["🔄 Extraction"]
        CLAUDE[Claude API<br/>LLM Extraction]
        PYDANTIC[Extracted Skill<br/>Pydantic Model]
    end

    subgraph Security["🔒 Security"]
        AUDIT[Security Audit<br/>Regex + LLM Review]
    end

    subgraph Serialization["📦 Serialization"]
        RDF[RDF Graph<br/>OWL 2 Triples]
    end

    subgraph Validation["✅ Validation"]
        SHACL[SHACL Validator<br/>Gatekeeper]
    end

    subgraph Output["📤 Output"]
        PASS["PASS<br/>Write .ttl"]
        FAIL["FAIL<br/>Block & Error"]
    end

    SKILL --> CLAUDE
    CLAUDE --> PYDANTIC
    PYDANTIC --> AUDIT
    AUDIT --> RDF
    RDF --> SHACL
    SHACL --> PASS
    SHACL --> FAIL

    style Input fill:#1a1a2e,stroke:#16213e,color:#fff
    style Extraction fill:#2196F3,stroke:#16213e,color:#fff
    style Security fill:#f39c12,stroke:#16213e,color:#fff
    style Serialization fill:#9333EA,stroke:#16213e,color:#fff
    style Validation fill:#e91e63,stroke:#16213e,color:#fff
    style Output fill:#00bf63,stroke:#16213e,color:#fff
    style PASS fill:#00bf63,stroke:#000,color:#fff
    style FAIL fill:#ff6b6b,stroke:#000,color:#fff`;
---

<section id="architecture" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        <span class="gradient-text">How It Works</span>
      </h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        From natural language to validated OWL 2 ontology in one pipeline.
      </p>
    </div>

    <div class="bg-bg-secondary border border-border rounded-xl p-6 overflow-x-auto">
      <pre class="mermaid text-sm">{mermaidCode}</pre>
    </div>

    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="p-4 bg-bg-secondary rounded-lg border border-border">
        <h4 class="font-semibold text-accent-cyan mb-2">Neural Layer</h4>
        <p class="text-sm text-text-muted">Claude extracts structured knowledge from natural language using tool-use.</p>
      </div>
      <div class="p-4 bg-bg-secondary rounded-lg border border-border">
        <h4 class="font-semibold text-accent-purple mb-2">Symbolic Layer</h4>
        <p class="text-sm text-text-muted">OWL 2 ontology stores knowledge with formal Description Logic semantics.</p>
      </div>
      <div class="p-4 bg-bg-secondary rounded-lg border border-border">
        <h4 class="font-semibold text-accent-mint mb-2">Query Layer</h4>
        <p class="text-sm text-text-muted">SPARQL provides precise, indexed retrieval for deterministic results.</p>
      </div>
    </div>
  </div>
</section>
