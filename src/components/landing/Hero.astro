---
import { type Lang, translations, defaultLang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = translations.hero[lang];
---

<section class="hero-section">
  <div class="hero-glow"></div>
  <div class="section-shell py-12 sm:py-16 lg:py-20 relative">
    <div class="max-w-2xl">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span class="badge-label">v0.1</span>
        <span class="badge-sep"></span>
        <span class="badge-text">{t.badgeTagline}</span>
      </div>

      <h1 class="hero-headline">
        <span>{t.headline.split(',')[0]},</span>{' '}
        <span class="headline-accent">{t.headline.split(',').slice(1).join(',')}</span>
      </h1>

      <p class="hero-subheadline">
        {t.subheadline}
      </p>

      <div class="hero-cta">
        <div class="command-shell-gradient p-[1px] rounded-lg">
          <div class="command-shell p-3 md:p-4 rounded-lg bg-bg-elevated">
            <code class="text-text-primary">npx ontoskills install mcp</code>
          </div>
        </div>
      </div>

      <div class="hero-buttons">
        <a href={`/${lang}/getting-started/`} class="hero-btn hero-btn-primary">
          {t.secondaryCta}
        </a>
        <a href="/ontostore/" class="hero-btn hero-btn-secondary">
          {t.cta}
        </a>
      </div>

      <div class="hero-stats">
        {t.stats.map((stat, index) => (
          <>
            <div class="stat-item">
              <div class="stat-value">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
            {index < t.stats.length - 1 && <div class="stat-divider"></div>}
          </>
        ))}
      </div>
    </div>

    <div class="hero-visual">
      <div class="code-window">
        <div class="code-header">
          <span class="code-dot code-dot-red"></span>
          <span class="code-dot code-dot-yellow"></span>
          <span class="code-dot code-dot-green"></span>
          <span class="code-title">SPARQL Query</span>
        </div>
        <pre class="code-content" set:html={`SELECT ?skill WHERE {
  ?skill oc:resolvesIntent "create_pdf" .
  ?skill oc:hasPayload ?payload .
}
<span class="code-comment">→ Returns in 0.3ms</span>
<span class="code-comment">→ Always the same result</span>`}></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(125, 211, 252, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-glow::before {
    content: '';
    position: absolute;
    bottom: -300px;
    left: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(171, 249, 204, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-glow::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(ellipse at center, rgba(146, 239, 244, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 20px;
    animation: fadeInUp 0.6s ease-out;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  .badge-label {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-cyan);
  }

  .badge-sep {
    width: 1px;
    height: 12px;
    background: var(--border);
  }

  .badge-text {
    font-size: 12px;
    color: var(--text-secondary);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 16px;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }


  .headline-accent {
    background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--accent-blue) 50%, var(--accent-mint) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    padding-right: 0.1em;
  }

  .hero-subheadline {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 560px;
    margin-bottom: 20px;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  .hero-cta {
    max-width: 400px;
    margin-bottom: 16px;
    animation: fadeInUp 0.6s ease-out 0.3s both;
  }

  .command-shell-gradient {
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-mint), var(--accent-purple));
    animation: gradientShift 4s ease infinite;
    background-size: 200% 200%;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
    animation: fadeInUp 0.6s ease-out 0.4s both;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
  }

  .hero-btn:focus {
    outline: none;
    box-shadow: 0 0 0 2px var(--accent-cyan), 0 0 0 4px var(--bg-primary);
  }

  .hero-btn-primary {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: white;
    color: black;
  }

  .hero-btn-primary:hover {
    background: #e5e5e5;
  }

  .hero-btn-secondary {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
  }

  .hero-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    animation: fadeInUp 0.6s ease-out 0.5s both;
  }

  .stat-item {
    text-align: left;
  }

  .stat-value {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-mint));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: linear-gradient(180deg, transparent, var(--accent-cyan), transparent);
    opacity: 0.3;
  }

  .hero-visual {
    display: none;
    position: absolute;
    right: 2%;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    animation: fadeInRight 0.8s ease-out 0.6s both;
  }

  @media (min-width: 1280px) {
    .hero-visual {
      display: block;
    }
  }

  @media (min-width: 1400px) {
    .hero-visual {
      right: 4%;
    }
  }

  .code-window {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    width: 380px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .code-dot-red { background: #ff5f57; }
  .code-dot-yellow { background: #febc2e; }
  .code-dot-green { background: #28c840; }

  .code-title {
    margin-left: 12px;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 11px;
    color: var(--text-muted);
  }

  .code-content {
    padding: 20px;
    margin: 0;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 13px;
    line-height: 1.8;
    color: var(--text-secondary);
    overflow-x: auto;
  }

  .code-keyword { color: #f9a8d4; }
  .code-property { color: #7dd3fc; }
  .code-string { color: #bbf7d0; }
  .code-comment {
    color: var(--text-muted);
    font-style: italic;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateY(-50%) translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }
</style>
