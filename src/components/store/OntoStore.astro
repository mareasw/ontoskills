---
import { OFFICIAL_STORE_INDEX_URL, OFFICIAL_STORE_REPO_URL } from '../../data/store';

interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
  showHeader?: boolean;
}

const {
  title = 'Store leaderboard',
  description = 'Search the official store, inspect published skills, and copy the exact install command.',
  compact = false,
  showHeader = true,
} = Astro.props;

const rootId = `market-${crypto.randomUUID()}`;
---

<section id="marketplace" class={`${compact ? 'py-14' : 'py-20'}`}>
  <div class="section-shell">
    {showHeader && (
      <div class="mb-8 max-w-3xl">
        <div class="mb-4 font-mono text-xs uppercase tracking-[0.24em] text-text-muted">Store</div>
        <h2 class="text-3xl font-semibold tracking-[-0.04em] text-text-primary sm:text-4xl">{title}</h2>
        <p class="mt-3 text-base leading-7 text-text-secondary">{description}</p>
      </div>
    )}

    <div id={rootId} class="border border-white/10 bg-bg-elevated">
      <div class="border-b border-white/10 p-4 sm:p-5">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
          <label class="flex items-center gap-3 border border-white/10 bg-bg-secondary px-4 py-3 lg:min-w-[22rem]">
            <span class="text-text-muted">/</span>
            <input
              class="w-full bg-transparent text-sm text-text-primary outline-none placeholder:text-text-muted"
              type="search"
              placeholder="Search skills..."
              data-role="search"
            />
          </label>
          <div class="flex items-center gap-3 text-sm text-text-secondary">
            <span data-role="count">Loading store…</span>
            <a href="/explore/" class="border border-white/10 px-3 py-2 hover:bg-white/5">Full page</a>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-[minmax(0,1fr)_auto] border-b border-white/10 bg-black/30 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.22em] text-text-muted sm:grid-cols-[64px_minmax(0,1fr)_140px]">
        <div class="hidden sm:block">#</div>
        <div>Skill</div>
        <div class="text-right">Install</div>
      </div>

      <div data-role="status" class="border-b border-dashed border-white/10 px-4 py-4 text-sm text-text-secondary">
        Connecting to the official store…
      </div>

      <div data-role="grid"></div>
    </div>
  </div>
</section>

<script define:vars={{ rootId, storeIndexUrl: OFFICIAL_STORE_INDEX_URL, storeRepoUrl: OFFICIAL_STORE_REPO_URL }} is:inline>
  const root = document.getElementById(rootId);
  const search = root?.querySelector('[data-role="search"]');
  const grid = root?.querySelector('[data-role="grid"]');
  const status = root?.querySelector('[data-role="status"]');
  const count = root?.querySelector('[data-role="count"]');

  const escapeHtml = (value) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const normalizeSkill = (pkg, skill) => {
    const qualifiedId = `${pkg.package_id}/${skill.id}`;
    return {
      packageId: pkg.package_id,
      skillId: skill.id,
      qualifiedId,
      description: skill.description || pkg.description || 'No description available.',
      aliases: Array.isArray(skill.aliases) ? skill.aliases : [],
      trustTier: pkg.trust_tier || 'verified',
      installCommand: `npx ontoskills install ${qualifiedId}`,
    };
  };

  let skills = [];

  const renderRow = (skill, index) => {
    const aliases = skill.aliases.length ? ` · ${escapeHtml(skill.aliases.join(', '))}` : '';
    return `
      <article class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-4 border-b border-white/10 px-4 py-4 transition hover:bg-white/[0.03] sm:grid-cols-[64px_minmax(0,1fr)_140px]">
        <div class="hidden font-mono text-sm text-text-muted sm:block">${index + 1}</div>
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <h3 class="text-base font-semibold text-text-primary">${escapeHtml(skill.skillId)}</h3>
            <span class="font-mono text-xs text-text-muted">${escapeHtml(skill.packageId)}</span>
            <span class="border border-white/10 px-2 py-0.5 text-[10px] uppercase tracking-[0.18em] text-text-muted">${escapeHtml(skill.trustTier)}</span>
          </div>
          <p class="mt-1 text-sm leading-6 text-text-secondary">${escapeHtml(skill.description)}</p>
          <div class="mt-2 font-mono text-xs text-text-muted">${escapeHtml(skill.qualifiedId)}${aliases}</div>
          <div class="mt-3 hidden border border-white/10 bg-black/30 p-3 text-xs text-text-secondary lg:block">
            <div class="mb-1 uppercase tracking-[0.18em] text-text-muted">Command</div>
            <code class="block break-all text-text-primary">${escapeHtml(skill.installCommand)}</code>
          </div>
        </div>
        <div class="flex flex-col items-end gap-2">
          <button type="button" data-copy="${escapeHtml(skill.installCommand)}" class="border border-white/10 px-3 py-2 text-sm text-text-primary hover:bg-white/5">
            Copy
          </button>
        </div>
      </article>
    `;
  };

  const render = () => {
    if (!grid || !count || !status) return;
    const query = (search?.value || '').trim().toLowerCase();
    const filtered = skills.filter((skill) => {
      const haystack = [
        skill.packageId,
        skill.skillId,
        skill.qualifiedId,
        skill.description,
        skill.aliases.join(' ')
      ]
        .join(' ')
        .toLowerCase();
      return haystack.includes(query);
    });

    count.textContent = `${filtered.length} skill${filtered.length === 1 ? '' : 's'}`;

    if (!skills.length) {
      status.textContent = '';
      const text1 = document.createTextNode('Unable to load store data. ');
      const link = document.createElement('a');
      link.href = storeRepoUrl;
      link.target = '_blank';
      link.rel = 'noopener';
      link.className = 'text-accent-cyan underline';
      link.textContent = 'Open the official store';
      const text2 = document.createTextNode('.');
      status.appendChild(text1);
      status.appendChild(link);
      status.appendChild(text2);
      grid.innerHTML = '';
      return;
    }

    status.textContent = query
      ? `Results for "${search.value.trim()}"`
      : 'Published skills from the official store.';

    if (!filtered.length) {
      grid.innerHTML = `<div class="px-4 py-6 text-sm text-text-secondary">No matching skills. Try hello, xlsx, docx, or office.</div>`;
      return;
    }

    grid.innerHTML = filtered.map(renderRow).join('');
  };

  const loadStore = async () => {
    try {
      const indexResponse = await fetch(storeIndexUrl, { mode: 'cors' });
      if (!indexResponse.ok) throw new Error(`Index request failed: ${indexResponse.status}`);
      const indexData = await indexResponse.json();
      const manifests = await Promise.all(
        (indexData.packages || []).map(async (entry) => {
          const manifestUrl = new URL(entry.manifest_url, storeIndexUrl).toString();
          const response = await fetch(manifestUrl, { mode: 'cors' });
          if (!response.ok) throw new Error(`Manifest request failed: ${response.status}`);
          return response.json();
        })
      );

      skills = manifests.flatMap((pkg) => (pkg.skills || []).map((skill) => normalizeSkill(pkg, skill)));
      skills.sort((left, right) => left.qualifiedId.localeCompare(right.qualifiedId));
      render();
    } catch (error) {
      console.error(error);
      skills = [];
      render();
    }
  };

  root?.addEventListener('click', async (event) => {
    const target = event.target.closest('[data-copy]');
    if (!target) return;
    const command = target.getAttribute('data-copy') ?? '';
    const original = target.textContent;
    try {
      await navigator.clipboard.writeText(command);
      target.textContent = 'Copied';
      setTimeout(() => {
        target.textContent = original;
      }, 1200);
    } catch {
      target.textContent = 'Failed';
      setTimeout(() => {
        target.textContent = original;
      }, 1200);
    }
  });

  search?.addEventListener('input', render);
  loadStore();
</script>
