---
import { OFFICIAL_STORE_INDEX_URL, OFFICIAL_STORE_REPO_URL } from '../../data/store';
import { type Lang, defaultLang } from '../../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
  showHeader?: boolean;
  lang?: Lang;
}

const {
  title = 'Store leaderboard',
  description = 'Search the official store, inspect published skills, and copy the exact install command.',
  compact = false,
  showHeader = true,
  lang = defaultLang,
} = Astro.props;

const rootId = `market-${crypto.randomUUID()}`;

// i18n strings
const i18n = {
  en: {
    searchPlaceholder: 'Search by skill, intent, or description...',
    loading: 'Loading store…',
    viewRepo: 'View Repo',
    connecting: 'Connecting to the official store…',
    noDescription: 'No description available.',
    official: 'official',
    verified: 'verified',
    install: 'Install',
    copyToClipboard: 'Copy to clipboard',
    unableToLoad: 'Unable to load store data. ',
    openStore: 'Open the official store',
    showingResults: 'Showing results for',
    allSkills: 'All published skills from the official registry.',
    noMatch: 'No matching skills found',
    trySearch: 'Try searching for: hello, xlsx, docx, or office',
    skill_one: 'skill',
    skill_other: 'skills',
  },
  zh: {
    searchPlaceholder: '按技能、意图或描述搜索...',
    loading: '加载商店中…',
    viewRepo: '查看仓库',
    connecting: '正在连接官方商店…',
    noDescription: '暂无描述。',
    official: '官方',
    verified: '已验证',
    install: '安装',
    copyToClipboard: '复制到剪贴板',
    unableToLoad: '无法加载商店数据。',
    openStore: '打开官方商店',
    showingResults: '显示搜索结果',
    allSkills: '来自官方注册表的所有已发布技能。',
    noMatch: '未找到匹配的技能',
    trySearch: '尝试搜索: hello, xlsx, docx, 或 office',
    skill_one: '个技能',
    skill_other: '个技能',
  },
};

const t = i18n[lang];
---

<section id="marketplace" class={`${compact ? 'py-14' : ''}`}>
  <div class="section-shell">
    {showHeader && (
      <div class="mb-8 max-w-3xl">
        <div class="mb-4 font-mono text-xs uppercase tracking-[0.24em] text-text-muted">Store</div>
        <h2 class="text-3xl font-semibold tracking-[-0.04em] text-text-primary sm:text-4xl">{title}</h2>
        <p class="mt-3 text-base leading-7 text-text-secondary">{description}</p>
      </div>
    )}

    <div id={rootId} class="rounded-2xl border border-white/10 bg-bg-elevated overflow-hidden">
      <!-- Search Bar -->
      <div class="border-b border-white/10 p-4 sm:p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="relative flex-1 lg:max-w-md">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              class="w-full bg-bg-secondary border border-white/10 rounded-xl pl-12 pr-4 py-3 text-sm text-text-primary outline-none placeholder:text-text-muted focus:border-cyan-500/50 focus:ring-1 focus:ring-cyan-500/20 transition-colors"
              type="search"
              placeholder={t.searchPlaceholder}
              data-role="search"
            />
          </div>
          <div class="flex items-center justify-between lg:justify-end gap-4">
            <span class="text-sm text-text-secondary" data-role="count">{t.loading}</span>
            <a href={OFFICIAL_STORE_REPO_URL} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-cyan-400 hover:text-cyan-300 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              {t.viewRepo}
            </a>
          </div>
        </div>
      </div>

      <!-- Status -->
      <div data-role="status" class="px-4 sm:px-6 py-4 text-sm text-text-secondary border-b border-white/5 bg-black/20">
        {t.connecting}
      </div>

      <!-- Results -->
      <div data-role="grid" class="divide-y divide-white/5"></div>
    </div>
  </div>
</section>

<script define:vars={{ rootId, storeIndexUrl: OFFICIAL_STORE_INDEX_URL, storeRepoUrl: OFFICIAL_STORE_REPO_URL, i18n: t }} is:inline>
  const root = document.getElementById(rootId);
  const search = root?.querySelector('[data-role="search"]');
  const grid = root?.querySelector('[data-role="grid"]');
  const status = root?.querySelector('[data-role="status"]');
  const count = root?.querySelector('[data-role="count"]');

  const escapeHtml = (value) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const normalizeSkill = (pkg, skill) => {
    const qualifiedId = `${pkg.package_id}/${skill.id}`;
    return {
      packageId: pkg.package_id,
      skillId: skill.id,
      qualifiedId,
      description: skill.description || pkg.description || 'No description available.',
      aliases: Array.isArray(skill.aliases) ? skill.aliases : [],
      trustTier: pkg.trust_tier || 'verified',
      installCommand: `npx ontoskills install ${qualifiedId}`,
    };
  };

  let skills = [];

  const renderRow = (skill, index) => {
    const aliases = skill.aliases.length ? skill.aliases.slice(0, 3).map(a => `<span class="px-2 py-0.5 rounded bg-white/5 text-xs text-text-muted">${escapeHtml(a)}</span>`).join('') : '';
    const trustBadge = skill.trustTier === 'official'
      ? `<span class="px-2 py-0.5 rounded bg-cyan-500/10 text-xs text-cyan-400 font-medium">${escapeHtml(i18n.official)}</span>`
      : skill.trustTier === 'verified'
        ? `<span class="px-2 py-0.5 rounded bg-green-500/10 text-xs text-green-400 font-medium">${escapeHtml(i18n.verified)}</span>`
        : `<span class="px-2 py-0.5 rounded bg-white/5 text-xs text-text-muted">${escapeHtml(skill.trustTier)}</span>`;

    return `
      <article class="group px-4 sm:px-6 py-5 hover:bg-white/[0.02] transition-colors">
        <div class="flex flex-col lg:flex-row lg:items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <h3 class="text-lg font-semibold text-text-primary">${escapeHtml(skill.skillId)}</h3>
              ${trustBadge}
            </div>
            <p class="text-sm text-text-secondary mb-3 leading-relaxed">${escapeHtml(skill.description)}</p>
            <div class="flex flex-wrap items-center gap-2">
              <code class="px-2 py-1 rounded bg-black/40 text-xs text-cyan-300 font-mono">${escapeHtml(skill.qualifiedId)}</code>
              ${aliases}
            </div>
          </div>
          <div class="lg:min-w-[280px]">
            <div class="relative px-3 py-2.5 rounded-lg bg-black/40 border border-white/5 group/install">
              <div class="flex items-center justify-between mb-1">
                <span class="text-[10px] uppercase tracking-wider text-text-muted">${escapeHtml(i18n.install)}</span>
                <button
                  type="button"
                  data-copy="${escapeHtml(skill.installCommand)}"
                  class="copy-btn opacity-50 group-hover/install:opacity-100 transition-opacity p-1 rounded hover:bg-white/5"
                  title="${escapeHtml(i18n.copyToClipboard)}"
                >
                  <svg class="w-3.5 h-3.5 text-text-muted hover:text-cyan-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
              <code class="text-xs text-text-primary font-mono break-all">${escapeHtml(skill.installCommand)}</code>
            </div>
          </div>
        </div>
      </article>
    `;
  };

  const render = () => {
    if (!grid || !count || !status) return;
    const query = (search?.value || '').trim().toLowerCase();
    const filtered = skills.filter((skill) => {
      const haystack = [
        skill.packageId,
        skill.skillId,
        skill.qualifiedId,
        skill.description,
        skill.aliases.join(' ')
      ]
        .join(' ')
        .toLowerCase();
      return haystack.includes(query);
    });

    count.textContent = `${filtered.length} ${filtered.length === 1 ? i18n.skill_one : i18n.skill_other}`;

    if (!skills.length) {
      status.innerHTML = '';
      const text1 = document.createTextNode(i18n.unableToLoad);
      const link = document.createElement('a');
      link.href = storeRepoUrl;
      link.target = '_blank';
      link.rel = 'noopener';
      link.className = 'text-cyan-400 hover:text-cyan-300 underline';
      link.textContent = i18n.openStore;
      const text2 = document.createTextNode('.');
      status.appendChild(text1);
      status.appendChild(link);
      status.appendChild(text2);
      grid.innerHTML = '';
      return;
    }

    status.textContent = query
      ? `${i18n.showingResults} "${search.value.trim()}"`
      : i18n.allSkills;

    if (!filtered.length) {
      grid.innerHTML = `
        <div class="px-4 sm:px-6 py-12 text-center">
          <svg class="w-12 h-12 mx-auto mb-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-text-secondary mb-2">${escapeHtml(i18n.noMatch)}</p>
          <p class="text-sm text-text-muted">${escapeHtml(i18n.trySearch)}</p>
        </div>
      `;
      return;
    }

    grid.innerHTML = filtered.map(renderRow).join('');
  };

  const loadStore = async () => {
    try {
      const indexResponse = await fetch(storeIndexUrl, { mode: 'cors' });
      if (!indexResponse.ok) throw new Error(`Index request failed: ${indexResponse.status}`);
      const indexData = await indexResponse.json();
      const manifests = await Promise.all(
        (indexData.packages || []).map(async (entry) => {
          const manifestUrl = new URL(entry.manifest_url, storeIndexUrl).toString();
          const response = await fetch(manifestUrl, { mode: 'cors' });
          if (!response.ok) throw new Error(`Manifest request failed: ${response.status}`);
          return response.json();
        })
      );

      skills = manifests.flatMap((pkg) => (pkg.skills || []).map((skill) => normalizeSkill(pkg, skill)));
      skills.sort((left, right) => left.qualifiedId.localeCompare(right.qualifiedId));
      render();
    } catch (error) {
      console.error(error);
      skills = [];
      render();
    }
  };

  root?.addEventListener('click', async (event) => {
    const target = event.target.closest('[data-copy]');
    if (!target) return;
    const command = target.getAttribute('data-copy') ?? '';
    const svg = target.querySelector('svg');
    const originalHtml = svg?.outerHTML || '';

    try {
      await navigator.clipboard.writeText(command);
      // Show checkmark
      if (svg) {
        svg.outerHTML = '<svg class="w-3.5 h-3.5 text-green-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
      }
      target.classList.add('opacity-100');
      setTimeout(() => {
        const newSvg = target.querySelector('svg');
        if (newSvg) newSvg.outerHTML = originalHtml;
        target.classList.remove('opacity-100');
      }, 1500);
    } catch {
      // Show X on failure
      if (svg) {
        svg.outerHTML = '<svg class="w-3.5 h-3.5 text-red-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>';
      }
      setTimeout(() => {
        const newSvg = target.querySelector('svg');
        if (newSvg) newSvg.outerHTML = originalHtml;
      }, 1500);
    }
  });

  search?.addEventListener('input', render);
  loadStore();
</script>
